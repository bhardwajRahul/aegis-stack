#!/usr/bin/env bash

set -e

# Configure UV environment based on execution context
if [ -n "$DOCKER_CONTAINER" ] || [ "$USER" = "root" ]; then
    echo "Running in Docker container..."

    # Docker uses /opt/venv (set in Dockerfile) to avoid volume mount conflicts
    export UV_PROJECT_ENVIRONMENT=/opt/venv
    export UV_LINK_MODE=copy
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"
else
    echo "Running in local environment, UV will use project defaults"

    # Ensure we don't inherit Docker environment variables
    unset UV_PROJECT_ENVIRONMENT
    unset UV_SYSTEM_PYTHON
fi

# Pop run_command from arguments
run_command="$1"
shift

if [ "$run_command" = "webserver" ]; then
    # Web server (FastAPI + Flet)
    uv run python -m app.entrypoints.webserver
elif [ "$run_command" = "scheduler" ]; then
    # Scheduler component
    uv run python -m app.entrypoints.scheduler
elif [ "$run_command" = "worker" ]; then
{%- if worker_backend == "taskiq" %}
    # Worker component using TaskIQ
    queue_type="${1:-system}"  # Default to system queue if not specified
    shift

    # Build the module path for the broker
    broker_module="app.components.worker.queues.${queue_type}:broker"

    # Worker processes (default: 2) - controls parallelism for CPU-bound tasks
    worker_processes="${WORKER_PROCESSES:-2}"

    # Dev hot-reload caveat: TaskIQ's ``--workers N`` (N>1) uses Python's
    # multiprocessing forkserver, which imports the broker module ONCE
    # and freezes that module state. Watchfiles then respawns individual
    # worker forks but they inherit the frozen modules — newly-added
    # @broker.task functions never reach the live workers and ``.kiq()``
    # enqueues land in Redis as "task not found".
    #
    # In dev (APP_ENV=dev or WORKER_WATCH=true) drop to one worker
    # process and skip the forkserver entirely. The single process
    # re-imports modules fresh on every restart, so new tasks register
    # immediately. TaskIQ's built-in ``--reload`` flag is broken in
    # current releases (FileWatcher: NoneType is not callable), so we
    # rely on the outer docker-compose watch loop to bounce the single
    # process when files change.
    if [ "$APP_ENV" = "dev" ] || [ "$WORKER_WATCH" = "true" ]; then
        worker_processes=1
        echo "Starting ${queue_type} taskiq worker with auto-reload (1 process, forkserver disabled)..."
    else
        echo "Starting ${queue_type} taskiq worker with ${worker_processes} processes..."
    fi
    exec uv run taskiq worker "${broker_module}" --workers "${worker_processes}" "$@"
{%- elif worker_backend == "dramatiq" %}
    # Worker component using Dramatiq
    queue_type="${1:-system}"  # Default to system queue if not specified
    shift

    # Broker module + queue module (dramatiq discovers actors by importing modules).
    # broker_dramatiq.py is renamed to broker.py during post-generation.
    broker_module="app.components.worker.broker"
    queue_module="app.components.worker.queues.${queue_type}"

    # Worker processes and threads
    worker_processes="${WORKER_PROCESSES:-2}"
    worker_threads="${WORKER_THREADS:-8}"

    # Dev hot-reload via dramatiq's built-in ``--watch DIR`` flag.
    # Gated by APP_ENV=dev or WORKER_WATCH=true to match the arq /
    # taskiq branches above — picking any backend in dev should feel
    # the same.
    if [ "$APP_ENV" = "dev" ] || [ "$WORKER_WATCH" = "true" ]; then
        echo "Starting ${queue_type} dramatiq worker with auto-reload (${worker_processes} processes, ${worker_threads} threads)..."
        exec uv run dramatiq "${broker_module}" "${queue_module}" --queues "${queue_type}" \
            --processes "${worker_processes}" --threads "${worker_threads}" --watch /code/app "$@"
    else
        echo "Starting ${queue_type} dramatiq worker with ${worker_processes} processes, ${worker_threads} threads..."
        exec uv run dramatiq "${broker_module}" "${queue_module}" --queues "${queue_type}" \
            --processes "${worker_processes}" --threads "${worker_threads}" "$@"
    fi
{%- else %}
    # Worker component using STANDARD arq CLI
    queue_type="${1:-system}"  # Default to system queue if not specified
    shift

    # Build the module path for the queue
    worker_module="app.components.worker.queues.${queue_type}.WorkerSettings"

    # Development mode auto-reload (APP_ENV from .env or WORKER_WATCH override)
    if [ "$APP_ENV" = "dev" ] || [ "$WORKER_WATCH" = "true" ]; then
        echo "Starting ${queue_type} worker with auto-reload..."
        exec uv run python -m arq "${worker_module}" --watch /code/app "$@"
    else
        echo "Starting ${queue_type} worker..."
        exec uv run python -m arq "${worker_module}" "$@"
    fi
{%- endif %}
{%- if include_htmx %}
elif [ "$run_command" = "build-watch" ]; then
    # Re-fingerprint web frontend assets whenever Tailwind (or a hand-edited
    # source) rewrites them, so the manifest never goes stale in dev.
    exec uv run python -m app.components.web_frontend.build_watch
{%- endif %}
elif [ "$run_command" = "lint" ]; then
    uv run ruff check .
elif [ "$run_command" = "typecheck" ]; then
    uv run mypy .
elif [ "$run_command" = "test" ]; then
    uv run pytest "$@"
elif [ "$run_command" = "health" ]; then
    uv run python -m app.cli.health check "$@"
elif [ "$run_command" = "help" ]; then
    echo "Available commands:"
    echo "  webserver   - Run FastAPI + Flet web server"
    echo "  scheduler   - Run scheduler component"
{%- if worker_backend == "taskiq" %}
    echo "  worker      - Run taskiq worker"
{%- elif worker_backend == "dramatiq" %}
    echo "  worker      - Run dramatiq worker"
{%- else %}
    echo "  worker      - Run arq worker (standard arq CLI patterns)"
{%- endif %}
{%- if include_htmx %}
    echo "  build-watch - Re-fingerprint web frontend assets on change"
{%- endif %}
    echo "  health      - Check system health status"
    echo "  lint        - Run ruff linting"
    echo "  typecheck   - Run mypy type checking"
    echo "  test        - Run pytest test suite"
    echo "  help        - Show this help message"
else
    echo "Unknown command: $run_command"
    echo "Available commands: webserver, scheduler, worker,{% if include_htmx %} build-watch,{% endif %} health, lint, typecheck, test, help"
    exit 1
fi
