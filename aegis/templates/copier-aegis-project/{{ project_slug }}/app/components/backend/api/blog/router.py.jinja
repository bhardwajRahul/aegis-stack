@router.get("/export")
async def export_posts_endpoint(
    format: Literal["markdown", "json"] = "markdown",
    status_filter: str | None = None,
    service: BlogService = Depends(get_blog_service),
{% if include_auth %}
    current_user: User = Depends(require_blog_writer),
{% endif %}
) -> StreamingResponse:
    """Download all posts as a markdown zip or single JSON document.

    Markdown is portable across SSGs (Hugo/Jekyll/Astro). JSON preserves
    full fidelity for round-tripping between Aegis projects.
    """
{% if include_auth %}
    _ = current_user
{% endif %}
    posts = await service.export_posts(status=status_filter)
    if format == "json":
        body = posts_to_json(posts).encode("utf-8")
        media_type = "application/json"
        filename = "blog-export.json"
    else:
        body = posts_to_zip(posts)
        media_type = "application/zip"
        filename = "blog-export.zip"
    return StreamingResponse(
        BytesIO(body),
        media_type=media_type,
        headers={"Content-Disposition": f'attachment; filename="{filename}"'},
    )


@router.post("/import", response_model=ImportResult)
async def import_posts_endpoint(
    file: UploadFile = File(...),
    on_conflict: ImportConflictPolicy = ImportConflictPolicy.SKIP,
    service: BlogService = Depends(get_blog_service),
{% if include_auth %}
    current_user: User = Depends(require_blog_writer),
{% endif %}
) -> ImportResult:
    """Import posts from a markdown file, zip of markdowns, or JSON document.

    Format is auto-detected from the upload's filename extension.
    """
{% if include_auth %}
    _ = current_user
{% endif %}
    data = await file.read()
    name = (file.filename or "").lower()
    try:
        if name.endswith(".json"):
            posts = json_to_posts(data.decode("utf-8"))
        elif name.endswith(".zip"):
            posts = zip_to_posts(data)
        elif name.endswith(".md") or name.endswith(".markdown"):
            posts = [
                markdown_to_post(
                    data.decode("utf-8"),
                    fallback_slug=name.rsplit("/", 1)[-1].rsplit(".", 1)[0],
                )
            ]
        else:
            raise HTTPException(
                status_code=400,
                detail="Unsupported file type. Use .md, .zip, or .json.",
            )
    except UnicodeDecodeError as e:
        raise HTTPException(status_code=400, detail=f"Invalid UTF-8: {e}") from e

    return await service.import_posts(posts, on_conflict=on_conflict)
