from fastapi import FastAPI

from app.components.backend.api import health
from app.components.backend.api import metrics
{%- if include_worker %}
from app.components.backend.api import events as worker_events
from app.components.backend.api import task_history
from app.components.backend.api import worker
{%- endif %}
{%- if scheduler_backend != "memory" %}
from app.components.backend.api import scheduler
{%- endif %}
{%- if include_auth %}
from app.components.backend.api.auth.router import router as auth_router
{%- endif %}
{%- if include_oauth %}
from app.components.backend.api.auth.oauth import router as oauth_router
{%- endif %}
{%- if include_auth_org %}
from app.components.backend.api.orgs.router import router as org_router
{%- endif %}
{%- if include_ai %}
from app.components.backend.api.ai.router import router as ai_router
{%- if ai_voice %}
from app.components.backend.api.voice.router import router as voice_router
{%- endif %}
{%- if ai_backend != "memory" and ollama_mode != "none" %}
from app.components.backend.api.llm.router import router as llm_router
{%- endif %}
{%- if ai_rag %}
from app.components.backend.api.rag.router import router as rag_router
{%- endif %}
{%- endif %}
{%- if include_comms %}
from app.components.backend.api.comms.router import router as comms_router
{%- endif %}
{%- if include_insights %}
from app.components.backend.api.insights import router as insights_router
{%- endif %}
{%- if include_payment %}
from app.components.backend.api.payment.router import router as payment_router
from app.components.backend.api.payment.pages import router as payment_pages_router
{%- endif %}
{%- if include_blog %}
from app.components.backend.api.blog.router import router as blog_router
{%- endif %}
{%- for p in _plugins | default([]) %}
{%- for r in p.wiring.routers %}
from {{ r.module }} import {{ r.symbol }} as {{ r.alias }}
{%- endfor %}
{%- endfor %}


def include_routers(app: FastAPI) -> None:
    """Include all API routers in the FastAPI app"""
    app.include_router(health.router, prefix="/health", tags=["health"])
    app.include_router(metrics.router, prefix="/api/v1")
    {%- if include_worker %}
    app.include_router(worker.router, prefix="/api/v1")
    app.include_router(task_history.router, prefix="/api/v1")
    app.include_router(worker_events.router, prefix="/events", tags=["events"])
    {%- endif %}
    {%- if scheduler_backend != "memory" %}
    app.include_router(scheduler.router, prefix="/api/v1")
    {%- endif %}
    {%- if include_auth %}
    app.include_router(auth_router, prefix="/api/v1")
    {%- endif %}
    {%- if include_oauth %}
    app.include_router(oauth_router, prefix="/api/v1")
    {%- endif %}
    {%- if include_auth_org %}
    app.include_router(org_router, prefix="/api/v1")
    {%- endif %}
    {%- if include_ai %}
    app.include_router(ai_router)
    {%- if ai_voice %}
    app.include_router(voice_router, prefix="/api/v1")
    {%- endif %}
    {%- if ai_backend != "memory" and ollama_mode != "none" %}
    app.include_router(llm_router, prefix="/api/v1")
    {%- endif %}
    {%- if ai_rag %}
    app.include_router(rag_router, prefix="/api/v1")
    {%- endif %}
    {%- endif %}
    {%- if include_comms %}
    app.include_router(comms_router, prefix="/api/v1")
    {%- endif %}
    {%- if include_insights %}
    app.include_router(insights_router, prefix="/api/v1")
    {%- endif %}
    {%- if include_payment %}
    app.include_router(payment_router, prefix="/api/v1")
    app.include_router(payment_pages_router)
    {%- endif %}
    {%- if include_blog %}
    app.include_router(blog_router, prefix="/api/v1")
    {%- endif %}
    {%- for p in _plugins | default([]) %}
    {%- for r in p.wiring.routers %}
    app.include_router({{ r.alias }}{% if r.prefix %}, prefix="{{ r.prefix }}"{% endif %}{% if r.tags %}, tags={{ r.tags | tojson }}{% endif %})
    {%- endfor %}
    {%- endfor %}
