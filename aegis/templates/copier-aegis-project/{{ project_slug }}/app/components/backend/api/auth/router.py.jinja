@router.post("/logout")
async def logout(
    response: Response,
    token: str | None = Depends(get_session_token),
    db: AsyncSession = Depends(get_async_db),
    audit: AuditEmitter = Depends(get_audit),
):
    """Logout by dropping the session cookie and revoking the current token.

    The cookie is dropped on every response — success OR failure. Browsers
    that arrive with a stale cookie must be able to log out and end up in
    a clean state, otherwise the user is stuck. Token blacklisting still
    requires a valid token (it's the identified action).

    On the failure path we build a ``JSONResponse`` ourselves and attach
    the cookie removal to it. FastAPI's injected ``Response`` parameter
    is bypassed when the handler raises ``HTTPException``, so we can't
    just modify it and rely on the framework to carry it through.
    """
    from app.services.auth.token_blacklist import token_blacklist

    # Auth gate. If invalid, build the 401 response ourselves so the
    # cookie-removal header actually rides on the wire.
    try:
        current_user = await get_current_user_from_token(token, db)
    except HTTPException as exc:
        failure = JSONResponse(
            status_code=exc.status_code,
            content={"detail": exc.detail},
            headers=getattr(exc, "headers", None) or {},
        )
        clear_session_cookie(failure)
        return failure

    # Success path. The injected Response *does* carry through here.
    clear_session_cookie(response)

    # Decode token to get jti and exp claims
    payload = verify_token(token) if token is not None else None
    if payload is None or "jti" not in payload:
        # Token has no jti — nothing to revoke (legacy token)
        await audit.emit("auth.logout", actor_id=current_user.id)
        return {"detail": "Logged out"}

    jti = payload["jti"]
    exp = payload.get("exp", 0)
    token_blacklist.revoke(jti, float(exp))
    await audit.emit("auth.logout", actor_id=current_user.id)
    return {"detail": "Logged out"}


