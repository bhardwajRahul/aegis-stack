@router.delete("/users/{user_id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_user(
    user_id: int,
    hard: bool = False,
    current_user: User = Depends(require_role("admin")),
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
) -> None:
    """Delete a user. Requires admin role.

    Default is a soft delete — the row stays with ``deleted_at`` set so it
    can be restored via ``POST /users/{user_id}/restore``. Pass ``?hard=true``
    for permanent removal (also drops org memberships and invites).
    """
    if hard:
        success = await user_service.hard_delete_user(user_id)
    else:
        success = await user_service.delete_user(user_id)
    if not success:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="User not found",
        )
    await audit.emit(
        "auth.user_hard_deleted" if hard else "auth.user_deleted",
        actor_id=current_user.id,
        target_type="user",
        target_id=user_id,
    )


@router.post("/users/{user_id}/restore", response_model=UserResponse)
async def restore_user(
    user_id: int,
    current_user: User = Depends(require_role("admin")),
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
) -> UserResponse:
    """Clear ``deleted_at`` on a soft-deleted user. Requires admin role.

    Returns 409 if another live user has claimed the same email since
    the soft delete — partial unique index would reject the restore.
    """
    try:
        restored = await user_service.restore_user(user_id)
    except RestoreConflict as exc:
        raise HTTPException(
            status_code=status.HTTP_409_CONFLICT, detail=str(exc)
        ) from exc
    if restored is None:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="User not found or not deleted",
        )
    await audit.emit(
        "auth.user_restored",
        actor_id=current_user.id,
        target_type="user",
        target_id=user_id,
    )
    return UserResponse.model_validate(restored)


@router.patch("/users/{user_id}/role", response_model=UserResponse)
async def set_user_role(
    user_id: int,
    body: RoleUpdateRequest,
    current_user: User = Depends(require_role("admin")),
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
) -> UserResponse:
    """Change a user's role. Requires admin role.

    Admins cannot mutate their own role — prevents accidental
    self-demotion of the only admin and self-promotion shenanigans.
    Another admin must perform the change.
    """
    if body.role not in VALID_ROLES:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"Invalid role. Must be one of: {sorted(VALID_ROLES)}",
        )
    if user_id == current_user.id:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="Cannot change your own role. Ask another admin.",
        )
    updated = await user_service.update_user(user_id, role=body.role)
    if not updated:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="User not found",
        )
    await audit.emit(
        "auth.role_changed",
        actor_id=current_user.id,
        target_type="user",
        target_id=user_id,
        new_role=body.role,
    )
    return UserResponse.model_validate(updated)
{% else %}
