@router.post("/register", response_model=UserResponse)
async def register(
    request: Request,
    response: Response,
    user_data: UserCreate,
    user_service: UserService = Depends(get_user_service),
{% if include_auth_org %}
    invite_service: InviteService = Depends(get_invite_service),
{% endif %}
    audit: AuditEmitter = Depends(get_audit),
):
    """Register a new user and sign them in via session cookie."""
    if not settings.REGISTRATION_ENABLED:
        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Registration is closed")
    register_limiter.check(request)

    # Check if user already exists
    existing_user = await user_service.get_user_by_email(user_data.email)
    if existing_user:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST, detail="Email already registered"
        )

    # Create new user
    user = await user_service.create_user(user_data)

    # Create email verification token
    await user_service.create_email_verification_token(user.id)
{% if include_auth_org %}

    # Accept any pending org invites for this email
    await invite_service.accept_pending_invites(user_data.email, user.id)
{% endif %}
    await audit.emit("auth.user_registered", actor_email=user_data.email, target_type="user", target_id=user.id)

    # Auto-sign-in: mint a JWT and attach it as the HttpOnly session cookie
    # so the client lands on a signed-in state without a second round-trip.
{% if include_auth_rbac %}
    access_token = create_access_token(data={"sub": user.email, "role": user.role})
{% else %}
    access_token = create_access_token(data={"sub": user.email})
{% endif %}
    set_session_cookie(response, access_token)

    return UserResponse.model_validate(user)

{% if include_auth_org %}

@router.post("/accept-invite", response_model=InviteResponse)
async def accept_invite(
    body: AcceptInviteRequest,
    token: str | None = Depends(get_session_token),
    db: AsyncSession = Depends(get_async_db),
    invite_service: InviteService = Depends(get_invite_service),
) -> InviteResponse:
    """Accept an org invite by token. Requires authentication."""
    current_user = await get_current_user_from_token(token, db)
    try:
        invite = await invite_service.accept_invite_by_token(
            body.token, current_user.email, current_user.id
        )
    except ValueError as e:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=str(e),
        )
    return InviteResponse.model_validate(invite)
{% endif %}


@router.post("/token")
async def login(
    request: Request,
    response: Response,
    form_data: OAuth2PasswordRequestForm = Depends(),
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
):
    """Login and get access token.

    Sets the HttpOnly ``aegis_session`` cookie *and* returns the token in
    the JSON body. Browser-based callers rely on the cookie; pure API
    clients (CLIs, tests) keep using the bearer token from the body.
    """
    login_limiter.check(request)

    ip_address = request.client.host if request.client else None

    # Get user by email (username field in OAuth2 form)
    user = await user_service.get_user_by_email(form_data.username)

    # Check account lockout before password verification
    if user and await user_service.is_account_locked(user):
        await audit.emit("auth.login_locked", actor_email=form_data.username)
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail=(
                "Account temporarily locked due to too many failed "
                "login attempts. Please try again later."
            ),
        )

    if not user or not verify_password(form_data.password, user.hashed_password):
        # Record the failed attempt if user exists
        if user:
            await user_service.record_failed_login(form_data.username)
        await audit.emit("auth.login_failed", actor_email=form_data.username, ip_address=ip_address)
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Incorrect email or password",
            headers={"WWW-Authenticate": "Bearer"},
        )

    # Successful login — reset failed attempts
    await user_service.reset_login_attempts(user.id)

    # Update last_login timestamp
    await user_service.update_user(
        user.id, last_login=datetime.now(UTC).replace(tzinfo=None)
    )

    # Create access token
{% if include_auth_rbac %}
    access_token = create_access_token(data={"sub": user.email, "role": user.role})
{% else %}
    access_token = create_access_token(data={"sub": user.email})
{% endif %}
    set_session_cookie(response, access_token)
    await audit.emit("auth.login_success", actor_email=form_data.username, actor_id=user.id, ip_address=ip_address)

    return {"access_token": access_token, "token_type": "bearer"}


@router.post("/password-reset/request")
async def request_password_reset(
    request: Request,
    body: PasswordResetRequest,
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
) -> dict[str, str]:
    """Request a password reset token.

    Always returns 200 regardless of whether the email exists,
    to avoid leaking account existence information.
    """
    password_reset_limiter.check(request)

    await user_service.create_password_reset_token(body.email)
    await audit.emit("auth.password_reset_requested", actor_email=body.email)
    return {"detail": "If an account exists, a reset token has been created"}


@router.post("/password-reset/confirm")
async def confirm_password_reset(
    body: PasswordResetConfirm,
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
) -> dict[str, str]:
    """Confirm a password reset using a valid token."""
    try:
        await user_service.reset_password(body.token, body.new_password)
    except ValueError as e:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=str(e),
        )
    await audit.emit("auth.password_reset_confirmed")
    return {"detail": "Password has been reset successfully"}


@router.post("/verify-email")
async def verify_email(
    body: EmailVerifyRequest,
    user_service: UserService = Depends(get_user_service),
    audit: AuditEmitter = Depends(get_audit),
) -> dict[str, str]:
    """Verify a user's email using a valid verification token."""
    try:
        await user_service.verify_email(body.token)
    except ValueError as e:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=str(e),
        )
    await audit.emit("auth.email_verified")
    return {"detail": "Email has been verified successfully"}


@router.get("/me", response_model=UserResponse)
