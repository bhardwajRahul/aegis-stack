router = APIRouter(prefix="/orgs", tags=["organizations"])

oauth2_scheme = OAuth2PasswordBearer(tokenUrl="/api/v1/auth/token", auto_error=False)


async def _get_current_user(
    token: str | None = Depends(oauth2_scheme),
    db: AsyncSession = Depends(get_async_db),
):
    """Get authenticated user."""
    return await get_current_user_from_token(token, db)


async def _require_org_role(
    membership_service: MembershipService,
    org_id: int,
    user_id: int,
    allowed_roles: set[str],
) -> OrganizationMember | None:
    """Check user has required org role. Raises 403 if not."""
    if not settings.AUTH_ENABLED:
        return None  # Skip org membership check in dev mode
    member = await membership_service.get_member(org_id, user_id)
    if not member or member.role not in allowed_roles:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Insufficient organization permissions",
        )
    return member


async def _require_admin_access(
    membership_service: MembershipService, org_id: int, user_id: int
) -> OrganizationMember | None:
    """Require admin or owner role."""
    return await _require_org_role(
        membership_service, org_id, user_id, {ORG_ROLE_ADMIN, ORG_ROLE_OWNER}
    )


async def _require_member_access(
    membership_service: MembershipService, org_id: int, user_id: int
) -> OrganizationMember | None:
    """Require any membership (owner, admin, or member)."""
    return await _require_org_role(
        membership_service, org_id, user_id, {ORG_ROLE_OWNER, ORG_ROLE_ADMIN, ORG_ROLE_MEMBER}
    )


# =============================================================================
# Organization CRUD
# =============================================================================


@router.post("", response_model=OrgResponse, status_code=status.HTTP_201_CREATED)
async def create_org(
    org_data: OrgCreate,
    user=Depends(_get_current_user),
    org_service: OrgService = Depends(get_org_service),
    membership_service: MembershipService = Depends(get_membership_service),
    audit: AuditEmitter = Depends(get_audit),
) -> OrgResponse:
    """Create a new organization. Creator becomes owner."""
    # Validate slug format
    if not SLUG_PATTERN.match(org_data.slug):
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="Invalid slug format. Must be lowercase alphanumeric with hyphens, cannot start or end with a hyphen.",
        )

    # Check slug uniqueness
    existing = await org_service.get_org_by_slug(org_data.slug)
    if existing:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="Organization slug already taken",
        )

    org = await org_service.create_org(org_data)

    # Add creator as owner (skip when auth disabled — dev user has no real DB row)
    if settings.AUTH_ENABLED:
        await membership_service.add_member(org.id, user.id, role=ORG_ROLE_OWNER)

    await audit.emit("auth.org_created", actor_id=user.id, target_type="org", target_id=org.id)

    return OrgResponse.model_validate(org)


