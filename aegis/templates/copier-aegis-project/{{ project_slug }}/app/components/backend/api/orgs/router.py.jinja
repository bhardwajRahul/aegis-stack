@router.get("/{org_id}/members", response_model=list[MemberResponse])
async def list_members(
    org_id: int,
    user=Depends(_get_current_user),
    membership_service: MembershipService = Depends(get_membership_service),
) -> list[MemberResponse]:
    """List organization members. Requires membership."""
    await _require_member_access(membership_service, org_id, user.id)

    members = await membership_service.list_org_members(org_id)
    return [MemberResponse.model_validate(m) for m in members]


@router.post(
    "/{org_id}/members",
    response_model=MemberResponse,
    status_code=status.HTTP_201_CREATED,
)
async def add_member(
    org_id: int,
    user_id: int,
    role: str = "member",
    user=Depends(_get_current_user),
    membership_service: MembershipService = Depends(get_membership_service),
    audit: AuditEmitter = Depends(get_audit),
) -> MemberResponse:
    """Add a member to organization. Requires admin or owner role."""
    await _require_admin_access(membership_service, org_id, user.id)

    # Check if already a member
    existing = await membership_service.get_member(org_id, user_id)
    if existing:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="User is already a member of this organization",
        )

    member = await membership_service.add_member(org_id, user_id, role)
    await audit.emit("auth.member_added", actor_id=user.id, org_id=org_id, target_type="user", target_id=user_id)
    return MemberResponse.model_validate(member)


@router.post(
    "/{org_id}/members/bulk",
    response_model=list[MemberResponse],
    status_code=status.HTTP_201_CREATED,
)
async def bulk_add_members(
    org_id: int,
    body: BulkAddMembersRequest,
    user=Depends(_get_current_user),
    membership_service: MembershipService = Depends(get_membership_service),
    audit: AuditEmitter = Depends(get_audit),
) -> list[MemberResponse]:
    """Bulk add members to organization. Requires admin or owner role."""
    await _require_admin_access(membership_service, org_id, user.id)

    validate_role(body.role, VALID_ORG_ROLES)

    added = await membership_service.bulk_add_members(org_id, body.user_ids, body.role)
    await audit.emit("auth.members_bulk_added", actor_id=user.id, org_id=org_id, detail=f"Added {len(added)} members")
    return [MemberResponse.model_validate(m) for m in added]


@router.patch("/{org_id}/members/{user_id}", response_model=MemberResponse)
async def update_member_role(
    org_id: int,
    user_id: int,
    role: str,
    user=Depends(_get_current_user),
    membership_service: MembershipService = Depends(get_membership_service),
    audit: AuditEmitter = Depends(get_audit),
) -> MemberResponse:
    """Update a member's role. Requires admin or owner role."""
    await _require_admin_access(membership_service, org_id, user.id)

    validate_role(role, VALID_ORG_ROLES)

    member = await membership_service.update_member_role(org_id, user_id, role)
    if not member:
        raise_not_found("Member")
    await audit.emit("auth.member_role_updated", actor_id=user.id, org_id=org_id, target_type="user", target_id=user_id, detail=f"Role changed to {role}")
    return MemberResponse.model_validate(member)


@router.delete(
    "/{org_id}/members/{user_id}", status_code=status.HTTP_204_NO_CONTENT
)
async def remove_member(
    org_id: int,
    user_id: int,
    user=Depends(_get_current_user),
    membership_service: MembershipService = Depends(get_membership_service),
    audit: AuditEmitter = Depends(get_audit),
) -> None:
    """Remove a member from organization. Owner cannot be removed."""
    await _require_admin_access(membership_service, org_id, user.id)

    # Prevent removing the owner
    target = await membership_service.get_member(org_id, user_id)
    if not target:
        raise_not_found("Member")
    if target.role == ORG_ROLE_OWNER:
        raise HTTPException(
            status_code=status.HTTP_403_FORBIDDEN,
            detail="Cannot remove the organization owner",
        )

    await membership_service.remove_member(org_id, user_id)
    await audit.emit("auth.member_removed", actor_id=user.id, org_id=org_id, target_type="user", target_id=user_id)


