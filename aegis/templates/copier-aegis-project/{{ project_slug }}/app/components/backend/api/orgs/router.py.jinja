@router.get("/{org_id}", response_model=OrgResponse)
async def get_org(
    org_id: int,
    user=Depends(_get_current_user),
    org_service: OrgService = Depends(get_org_service),
    membership_service: MembershipService = Depends(get_membership_service),
) -> OrgResponse:
    """Get organization details. Requires membership."""
    org = await org_service.get_org_by_id(org_id)
    if not org:
        raise_not_found("Organization")
    await _require_member_access(membership_service, org_id, user.id)
    return OrgResponse.model_validate(org)


@router.patch("/{org_id}", response_model=OrgResponse)
async def update_org(
    org_id: int,
    name: str | None = None,
    description: str | None = None,
    user=Depends(_get_current_user),
    org_service: OrgService = Depends(get_org_service),
    membership_service: MembershipService = Depends(get_membership_service),
) -> OrgResponse:
    """Update organization. Requires admin or owner role."""
    await _require_admin_access(membership_service, org_id, user.id)

    updates: dict[str, str] = {}
    if name is not None:
        updates["name"] = name
    if description is not None:
        updates["description"] = description

    if not updates:
        raise_bad_request("No fields to update")

    org = await org_service.update_org(org_id, **updates)
    if not org:
        raise_not_found("Organization")
    return OrgResponse.model_validate(org)


@router.delete("/{org_id}", status_code=status.HTTP_204_NO_CONTENT)
async def delete_org(
    org_id: int,
    user=Depends(_get_current_user),
    org_service: OrgService = Depends(get_org_service),
    membership_service: MembershipService = Depends(get_membership_service),
    audit: AuditEmitter = Depends(get_audit),
) -> None:
    """Delete organization. Requires owner role."""
    await _require_org_role(membership_service, org_id, user.id, {ORG_ROLE_OWNER})

    success = await org_service.delete_org(org_id)
    if not success:
        raise_not_found("Organization")

    await audit.emit("auth.org_deleted", actor_id=user.id, target_type="org", target_id=org_id)


