def _safe_next(target: str | None) -> str:
    """Return ``target`` only if it is a local path, else ``/``.

    ``?next=`` arrives from the URL, so it is attacker-controlled. Anything
    not starting with a single ``/`` is discarded — which also rules out
    ``//evil.example`` protocol-relative URLs — otherwise sign-in becomes an
    open redirect.
    """
    if not target or not target.startswith("/") or target.startswith("//"):
        return "/"
    return target


def _current_user_or_redirect(
    request: Request,
    user: User | None,
) -> RedirectResponse | None:
    """Bounce anonymous visitors to ``/login?next=<here>``, else ``None``.

    Page-level protection is opt-in, exactly like the API's. A page that
    needs a signed-in user takes ``user: User | None = Depends(get_optional_user)``
    and returns this result when it is not None::

        bounce = _current_user_or_redirect(request, user)
        if bounce:
            return bounce

    There is deliberately no default-deny middleware: a page without this
    call is public, the same contract ``Depends(get_current_active_user)``
    gives the API.
    """
    if user is not None:
        return None
    return RedirectResponse(
        url=f"/login?next={quote(request.url.path)}", status_code=303
    )


@router.get("/login", response_class=HTMLResponse, include_in_schema=False)
async def login_page(request: Request, next: str = "") -> HTMLResponse:
    return templates.TemplateResponse(
        request=request,
        name="pages/auth/login.html",
        context={"next": _safe_next(next) if next else ""},
    )


@router.post("/login", include_in_schema=False)
async def login_submit(
    request: Request,
    email: Annotated[str, Form()],
    password: Annotated[str, Form()],
    next: Annotated[str, Form()] = "",
    user_service: UserService = Depends(get_user_service),
    refresh_service: RefreshService = Depends(get_refresh_service),
    audit: AuditEmitter = Depends(get_audit),
    _rate_limit: None = Depends(login_rate_limit),
) -> RedirectResponse:
    """Sign in from the page form.

    Delegates to the API's own login handler rather than reimplementing it:
    account lockout, failed-attempt tracking, audit events, token minting and
    cookie scoping all live there, and a second copy here would drift out of
    step with them. The rate limiter is re-declared above so this path is
    limited by the same bucket as the API.

    The redirect is handed in as the ``response``, so the session and refresh
    cookies the API handler sets land on the 303 the browser follows.
    """
    redirect = RedirectResponse(url=_safe_next(next), status_code=303)
    try:
        await api_login(
            request=request,
            response=redirect,
            form_data=OAuth2PasswordRequestForm(username=email, password=password),
            user_service=user_service,
            refresh_service=refresh_service,
            audit=audit,
            _rate_limit=None,
        )
    except HTTPException:
        # The API answers wrong-password and locked-account with the same 401
        # so neither reveals whether the email exists. Keep that property:
        # one message, one destination.
        return RedirectResponse(url="/login?error=invalid", status_code=303)
    return redirect


