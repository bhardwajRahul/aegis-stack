@router.post("/register", include_in_schema=False)
async def register_submit(
    request: Request,
    email: Annotated[str, Form()],
    password: Annotated[str, Form()],
    full_name: Annotated[str, Form()] = "",
    next: Annotated[str, Form()] = "",
    user_service: UserService = Depends(get_user_service),
    refresh_service: RefreshService = Depends(get_refresh_service),
{%- if include_auth_org %}
    invite_service: InviteService = Depends(get_invite_service),
{%- endif %}
    audit: AuditEmitter = Depends(get_audit),
    _rate_limit: None = Depends(register_rate_limit),
) -> RedirectResponse:
    """Create an account from the page form.

    Same delegation as ``login_submit``: the API handler owns the closed-
    signup check, duplicate detection, the verification email and the
    cookies. Every dependency the API handler declares must be threaded
    through here — an omitted one stays a bare ``Depends`` sentinel and
    blows up the moment the handler body touches it.
    """
    redirect = RedirectResponse(url="/verify-pending", status_code=303)
    try:
        await api_register(
            request=request,
            response=redirect,
            user_data=UserCreate(
                email=email, password=password, full_name=full_name or None
            ),
            user_service=user_service,
            refresh_service=refresh_service,
{%- if include_auth_org %}
            invite_service=invite_service,
{%- endif %}
            audit=audit,
            _rate_limit=None,
        )
    except HTTPException as exc:
        if exc.status_code == 403:
            return RedirectResponse(url="/register?error=closed", status_code=303)
        if exc.status_code == 400:
            return RedirectResponse(url="/register?error=exists", status_code=303)
        return RedirectResponse(url="/register?error=invalid", status_code=303)
    return redirect


@router.get("/logout", include_in_schema=False)
async def logout() -> RedirectResponse:
    """Sign out and land back on the public landing page.

    A GET so a plain link works. Both cookies are dropped: leaving the
    refresh cookie would let the next page load silently resume the session.
    """
    redirect = RedirectResponse(url="/", status_code=303)
    clear_session_cookie(redirect)
    redirect.delete_cookie(REFRESH_COOKIE_NAME, path="/api/v1/auth")
    return redirect


