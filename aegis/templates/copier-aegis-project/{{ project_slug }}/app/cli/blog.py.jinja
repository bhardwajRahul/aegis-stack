# Export / Import


@app.command(
    help=lazy_t("blog.help_export"),
    epilog=_ex(
        "{{ project_slug }} blog export ./out",
        "{{ project_slug }} blog export ./out --status published",
        "{{ project_slug }} blog export blog.json --format json",
    ),
)
def export(
    path: str = typer.Argument(..., help=lazy_t("blog.arg_export_path")),
    fmt: str = typer.Option(
        "markdown", "--format", "-f", help=lazy_t("blog.opt_format")
    ),
    status_filter: str | None = typer.Option(
        None, "--status", "-s", help=lazy_t("blog.opt_status")
    ),
) -> None:
    """Export posts to markdown files or a JSON document."""
    asyncio.run(_export(path, fmt, status_filter))


async def _export(path: str, fmt: str, status_filter: str | None) -> None:
    from pathlib import Path

    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService
    from app.services.blog.serialization import (
        post_to_markdown,
        posts_to_json,
    )

    if fmt not in ("markdown", "json"):
        console.print(f"[red]{t('blog.export_bad_format', fmt=fmt)}[/red]")
        raise typer.Exit(2)

    async with get_async_session() as session:
        service = BlogService(session)
        posts = await service.export_posts(status=status_filter)

    if not posts:
        console.print(f"[dim]{t('blog.no_posts')}[/dim]")
        return

    target = Path(path)
    if fmt == "json":
        target.write_text(posts_to_json(posts), encoding="utf-8")
        console.print(
            f"[green]{t('blog.exported_json', count=len(posts), path=target)}[/green]"
        )
        return

    target.mkdir(parents=True, exist_ok=True)
    seen: set[str] = set()
    for post in posts:
        base = post.slug or "post"
        name = f"{base}.md"
        counter = 1
        while name in seen:
            counter += 1
            name = f"{base}-{counter}.md"
        seen.add(name)
        (target / name).write_text(post_to_markdown(post), encoding="utf-8")

    console.print(
        f"[green]{t('blog.exported_markdown', count=len(posts), path=target)}[/green]"
    )


@app.command(
    name="import",
    help=lazy_t("blog.help_import"),
    epilog=_ex(
        "{{ project_slug }} blog import ./posts",
        "{{ project_slug }} blog import backup.zip",
        "{{ project_slug }} blog import blog.json --on-conflict overwrite",
    ),
)
def import_(
    path: str = typer.Argument(..., help=lazy_t("blog.arg_import_path")),
    on_conflict: ImportConflictPolicy = typer.Option(
        ImportConflictPolicy.SKIP,
        "--on-conflict",
        help=lazy_t("blog.opt_on_conflict"),
    ),
) -> None:
    """Import posts from a markdown file/dir, a zip archive, or a JSON document."""
    asyncio.run(_import(path, on_conflict))


async def _import(path: str, on_conflict: "ImportConflictPolicy") -> None:
    from pathlib import Path

    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService
    from app.services.blog.schemas import ImportedPost
    from app.services.blog.serialization import (
        json_to_posts,
        markdown_to_post,
        zip_to_posts,
    )

    source = Path(path)
    if not source.exists():
        console.print(f"[red]{t('blog.import_path_missing', path=path)}[/red]")
        raise typer.Exit(1)

    posts: list[ImportedPost] = []
    if source.is_dir():
        for md_path in sorted(source.rglob("*.md")):
            text = md_path.read_text(encoding="utf-8")
            posts.append(markdown_to_post(text, fallback_slug=md_path.stem))
    elif source.suffix.lower() == ".zip":
        posts = zip_to_posts(source.read_bytes())
    elif source.suffix.lower() == ".json":
        posts = json_to_posts(source.read_text(encoding="utf-8"))
    elif source.suffix.lower() in (".md", ".markdown"):
        posts = [
            markdown_to_post(
                source.read_text(encoding="utf-8"), fallback_slug=source.stem
            )
        ]
    else:
        console.print(
            f"[red]{t('blog.import_bad_type', path=path)}[/red]"
        )
        raise typer.Exit(2)

    if not posts:
        console.print(f"[dim]{t('blog.import_empty')}[/dim]")
        return

    async with get_async_session() as session:
        service = BlogService(session)
        result = await service.import_posts(posts, on_conflict=on_conflict)

    table = Table(title=t("blog.import_summary_title"))
    table.add_column(t("blog.col_kind"), style="dim")
    table.add_column(t("blog.col_count"), justify="right")
    table.add_row(t("blog.col_created"), f"[green]{result.created}[/green]")
    table.add_row(t("blog.col_updated"), f"[cyan]{result.updated}[/cyan]")
    table.add_row(t("blog.col_skipped"), f"[yellow]{result.skipped}[/yellow]")
    table.add_row(t("blog.col_failed"), f"[red]{result.failed}[/red]")
    console.print(table)

    if result.errors:
        console.print()
        for err in result.errors:
            console.print(f"  [red]{err.slug or '(unknown)'}[/red]: {err.message}")
