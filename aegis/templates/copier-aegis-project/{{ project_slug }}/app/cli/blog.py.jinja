    if name is None and new_slug is None:
        console.print(f"[red]{t('blog.tag_update_no_changes')}[/red]")
        raise typer.Exit(2)
    asyncio.run(_tag_update(slug, name, new_slug))


async def _tag_update(slug: str, name: str | None, new_slug: str | None) -> None:
    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService
    from app.services.blog.schemas import BlogTagUpdate

    async with get_async_session() as session:
        service = BlogService(session)
        tag_id = await _resolve_tag_id(service, slug)
        if tag_id is None:
            console.print(f"[red]{t('blog.tag_not_found', slug=slug)}[/red]")
            raise typer.Exit(1)
        try:
            tag = await service.update_tag(
                tag_id, BlogTagUpdate(name=name, slug=new_slug)
            )
        except ValueError as e:
            console.print(f"[red]{e}[/red]")
            raise typer.Exit(1) from e

    if tag is None:
        console.print(f"[red]{t('blog.tag_not_found', slug=slug)}[/red]")
        raise typer.Exit(1)

    console.print(
        f"[green]{t('blog.tag_updated', name=tag.name, slug=tag.slug)}[/green]"
    )


