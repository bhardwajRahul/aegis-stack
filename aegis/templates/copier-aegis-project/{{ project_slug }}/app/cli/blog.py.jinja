"""
Blog service CLI commands.

Read commands inspect posts and tags. State-transition commands publish,
archive, or delete a post by slug. Tag CRUD lets operators seed and curate
taxonomy from scripts. Authoring (post body editing) stays in the dashboard.
"""

import asyncio

import typer
from app.i18n import lazy_t, t
from app.services.blog.constants import ImportConflictPolicy
from rich.console import Console
from rich.table import Table


def _ex(*lines: str) -> str:
    """Render an indented Examples block for a command epilog.

    Rich (typer's default help renderer) collapses single newlines into
    soft wraps. Joining examples with a blank line keeps each on its own
    visual line.
    """
    body = "\n\n".join(lines)
    return f"Examples:\n\n{body}"


BLOG_EPILOG = _ex(
    "{{ project_slug }} blog status",
    "{{ project_slug }} blog posts --status draft --limit 10",
    "{{ project_slug }} blog post my-first-post",
    "{{ project_slug }} blog publish my-first-post",
    '{{ project_slug }} blog tag-create "Release Notes"',
)

app = typer.Typer(help=lazy_t("blog.help"), epilog=BLOG_EPILOG)
console = Console()

_PAGE_SIZE_MAX = 100
_RESOLVE_PAGE_SIZE = 100
_RESOLVE_PAGE_LIMIT = 50


def _format_dt(value: object) -> str:
    """Render a datetime cell, falling back to a dim dash."""
    if value is None:
        return "[dim]-[/dim]"
    if hasattr(value, "strftime"):
        return value.strftime("%Y-%m-%d %H:%M")  # type: ignore[union-attr]
    return str(value)


def _status_color(status: str) -> str:
    return {
        "draft": "yellow",
        "published": "green",
        "archived": "dim",
    }.get(status, "white")


async def _resolve_post_id(service: object, slug: str) -> int | None:
    """Find a post id by slug across all statuses (paginated scan)."""
    page = 1
    while page <= _RESOLVE_PAGE_LIMIT:
        posts, total = await service.list_posts(  # type: ignore[attr-defined]
            page=page, page_size=_RESOLVE_PAGE_SIZE
        )
        for post in posts:
            if post.slug == slug:
                return post.id
        if page * _RESOLVE_PAGE_SIZE >= total:
            return None
        page += 1
    return None


async def _resolve_tag_id(service: object, slug: str) -> int | None:
    """Find a tag id by slug."""
    tags = await service.list_tags()  # type: ignore[attr-defined]
    for tag in tags:
        if tag.slug == slug:
            return tag.id
    return None


# Read commands


@app.command(
    help=lazy_t("blog.help_status"),
    epilog=_ex("{{ project_slug }} blog status"),
)
def status() -> None:
    """Show blog post counts and latest activity.

    Examples:

        {{ project_slug }} blog status
    """
    asyncio.run(_status())


async def _status() -> None:
    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService

    async with get_async_session() as session:
        service = BlogService(session)
        summary = await service.get_health_summary()

    console.print()
    console.print(f"[bold]{t('blog.status_title')}[/bold]")
    console.print()

    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("Label", style="dim")
    table.add_column("Value")

    table.add_row(t("blog.col_total_posts"), str(summary.total_posts))
    table.add_row(
        t("blog.col_drafts"),
        f"[yellow]{summary.draft_posts}[/yellow]",
    )
    table.add_row(
        t("blog.col_published"),
        f"[green]{summary.published_posts}[/green]",
    )
    table.add_row(
        t("blog.col_archived"),
        f"[dim]{summary.archived_posts}[/dim]",
    )
    table.add_row(t("blog.col_tags"), str(summary.tag_count))
    if summary.stale_draft_count:
        table.add_row(
            t("blog.col_stale_drafts"),
            f"[red]{summary.stale_draft_count}[/red]",
        )

    latest = summary.latest_published_post
    if latest:
        table.add_row(
            t("blog.col_latest_published"),
            f"{latest.get('title')} ([dim]{latest.get('slug')}[/dim])",
        )

    console.print(table)
    console.print()


@app.command(
    help=lazy_t("blog.help_posts"),
    epilog=_ex(
        "{{ project_slug }} blog posts",
        "{{ project_slug }} blog posts --status draft",
        "{{ project_slug }} blog posts --tag release-notes --limit 50",
    ),
)
def posts(
    status_filter: str | None = typer.Option(
        None, "--status", "-s", help=lazy_t("blog.opt_status")
    ),
    tag: str | None = typer.Option(
        None, "--tag", "-t", help=lazy_t("blog.opt_tag")
    ),
    limit: int = typer.Option(
        20, "--limit", "-n", help=lazy_t("blog.opt_limit")
    ),
) -> None:
    """List blog posts with optional status and tag filters.

    Examples:

        {{ project_slug }} blog posts
        {{ project_slug }} blog posts --status draft
        {{ project_slug }} blog posts --tag release-notes --limit 50
    """
    asyncio.run(_posts(status_filter, tag, limit))


async def _posts(status_filter: str | None, tag: str | None, limit: int) -> None:
    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService

    page_size = min(max(limit, 1), _PAGE_SIZE_MAX)

    async with get_async_session() as session:
        service = BlogService(session)
        rows, total = await service.list_posts(
            page=1, page_size=page_size, status=status_filter, tag=tag
        )

    if not rows:
        console.print(f"[dim]{t('blog.no_posts')}[/dim]")
        return

    table = Table(title=t("blog.posts_title", total=total))
    table.add_column(t("blog.col_id"), style="dim")
    table.add_column(t("blog.col_slug"))
    table.add_column(t("blog.col_title"))
    table.add_column(t("blog.col_status"))
    table.add_column(t("blog.col_author"))
    table.add_column(t("blog.col_published_at"))

    for post in rows:
        color = _status_color(post.status)
        table.add_row(
            str(post.id),
            post.slug,
            post.title,
            f"[{color}]{post.status}[/{color}]",
            post.author_name or "[dim]-[/dim]",
            _format_dt(post.published_at),
        )

    console.print(table)


@app.command(
    name="post",
    help=lazy_t("blog.help_post"),
    epilog=_ex("{{ project_slug }} blog post my-first-post"),
)
def post_show(
    slug: str = typer.Argument(..., help=lazy_t("blog.arg_slug")),
) -> None:
    """Show a single post's metadata (not the full body, use the editor).

    Examples:

        {{ project_slug }} blog post my-first-post
    """
    asyncio.run(_post_show(slug))


async def _post_show(slug: str) -> None:
    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService

    async with get_async_session() as session:
        service = BlogService(session)
        post_id = await _resolve_post_id(service, slug)
        if post_id is None:
            console.print(f"[red]{t('blog.post_not_found', slug=slug)}[/red]")
            raise typer.Exit(1)
        post = await service.get_post(post_id)

    if post is None:
        console.print(f"[red]{t('blog.post_not_found', slug=slug)}[/red]")
        raise typer.Exit(1)

    color = _status_color(post.status)
    console.print()
    console.print(f"[bold]{post.title}[/bold]")
    console.print()

    table = Table(show_header=False, box=None, padding=(0, 2))
    table.add_column("Label", style="dim")
    table.add_column("Value")

    table.add_row(t("blog.col_id"), str(post.id))
    table.add_row(t("blog.col_slug"), post.slug)
    table.add_row(t("blog.col_status"), f"[{color}]{post.status}[/{color}]")
    table.add_row(t("blog.col_author"), post.author_name or "-")
    table.add_row(t("blog.col_created_at"), _format_dt(post.created_at))
    table.add_row(t("blog.col_updated_at"), _format_dt(post.updated_at))
    table.add_row(t("blog.col_published_at"), _format_dt(post.published_at))
    if post.tags:
        table.add_row(
            t("blog.col_tags"),
            ", ".join(tag.slug for tag in post.tags),
        )
    if post.excerpt:
        table.add_row(t("blog.col_excerpt"), post.excerpt)

    console.print(table)
    console.print()
    console.print(f"[dim]{t('blog.body_hint')}[/dim]")


