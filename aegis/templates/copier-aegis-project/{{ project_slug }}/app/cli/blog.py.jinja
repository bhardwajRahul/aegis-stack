    slug: str = typer.Argument(..., help=lazy_t("blog.arg_slug")),
    yes: bool = typer.Option(
        False, "--yes", "-y", help=lazy_t("blog.opt_yes")
    ),
) -> None:
    """Permanently delete a post and its tag links.

    Examples:

        {{ project_slug }} blog delete obsolete-post --yes
    """
    asyncio.run(_delete(slug, yes))


async def _delete(slug: str, yes: bool) -> None:
    from app.core.db import get_async_session
    from app.services.blog.blog_service import BlogService

    if not yes:
        confirmed = typer.confirm(t("blog.confirm_delete_post", slug=slug))
        if not confirmed:
            console.print(f"[dim]{t('blog.cancelled')}[/dim]")
            raise typer.Exit(0)

    async with get_async_session() as session:
        service = BlogService(session)
        post_id = await _resolve_post_id(service, slug)
        if post_id is None:
            console.print(f"[red]{t('blog.post_not_found', slug=slug)}[/red]")
            raise typer.Exit(1)
        ok = await service.delete_post(post_id)

    if not ok:
        console.print(f"[red]{t('blog.post_not_found', slug=slug)}[/red]")
        raise typer.Exit(1)

    console.print(f"[red]{t('blog.deleted', slug=slug)}[/red]")


