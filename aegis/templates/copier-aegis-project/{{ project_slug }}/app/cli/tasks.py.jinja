"""
Scheduled task CLI commands.

Provides command-line interface for listing scheduled jobs.
"""

import asyncio

from rich import print as rprint
from rich.console import Console
from rich.table import Table
import typer

from app.i18n import lazy_t, t
from app.services.scheduler import ScheduledTaskManager
from app.services.scheduler.models import ScheduledTask

app = typer.Typer(
    name="tasks",
    help=lazy_t("tasks.help"),
    no_args_is_help=True,
)

console = Console()


def _translate_job_name(job_id: str, stored_name: str | None) -> str:
    """Translate known job names at display time, fall back to stored name."""
    key = f"tasks.job.{job_id}"
    translated = t(key)
    # If t() returns the key itself, no translation exists — use stored name
    if translated == key:
        return stored_name or job_id
    return translated


@app.command("list", help=lazy_t("tasks.help_list"))
def list_jobs() -> None:
    rprint(f"[bold blue]{t('tasks.listing_jobs')}[/bold blue]")

    try:
        tasks = asyncio.run(_get_scheduled_tasks())

        if not tasks:
            rprint(f"[yellow]{t('tasks.no_jobs_found')}[/yellow]")
            return

        table = Table(
            title=t("tasks.scheduled_jobs_title"),
            show_header=True,
            header_style="bold magenta",
        )
        table.add_column(t("tasks.job_id_column"), style="cyan", no_wrap=True)
        table.add_column(t("tasks.name_column"), style="green")
        table.add_column(t("tasks.status_column"), style="bold")
        table.add_column(t("tasks.next_run_column"), style="yellow")
        table.add_column(t("tasks.trigger_column"), style="dim")

        for task in tasks:
            status_color = "green" if task.is_active else "red"
            next_run = (
                task.next_run_time.strftime("%Y-%m-%d %H:%M:%S")
                if task.next_run_time
                else t("tasks.not_scheduled")
            )

            table.add_row(
                task.job_id,
                _translate_job_name(task.job_id, task.name),
                (
                    f"[{status_color}]"
                    f"{t('tasks.active') if task.is_active else t('tasks.paused')}"
                    f"[/{status_color}]"
                ),
                next_run,
                task.trigger_type or t("shared.unknown"),
            )

        console.print(table)
        rprint(f"\n[cyan]{t('tasks.total_jobs')}[/cyan] {len(tasks)}")

    except Exception as e:
        rprint(f"[red]{t('tasks.list_failed')}[/red] {e}")
        raise typer.Exit(1)


async def _get_scheduled_tasks() -> list[ScheduledTask]:
    """Get list of scheduled tasks from the scheduler."""
    manager = ScheduledTaskManager()
    return await manager.list_tasks()


if __name__ == "__main__":
    app()
{%- endif -%}