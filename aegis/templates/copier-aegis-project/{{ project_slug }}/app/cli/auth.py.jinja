@app.command(help=lazy_t("auth.help_promote_user"))
def promote_user(
    email: str = typer.Option(..., help=lazy_t("auth.opt_promote_email")),
    role: str = typer.Option("admin", help=lazy_t("auth.opt_promote_role")),
) -> None:
    asyncio.run(_promote_user(email, role))


async def _promote_user(email: str, role: str) -> None:
    """Async implementation of promote_user."""
    if role not in VALID_ROLES:
        theme.bad(
            t("auth.invalid_role", role=role, valid=", ".join(sorted(VALID_ROLES)))
        )
        raise typer.Exit(1)

    try:
        async with get_async_session() as session:
            user_service = UserService(session)
            user = await user_service.get_user_by_email(email)
            if not user:
                theme.bad(t("auth.user_not_found", email=email))
                raise typer.Exit(1)

            previous_role = user.role
            updated = await user_service.update_user(user.id, role=role)
            assert updated is not None  # we just fetched it

            theme.good(
                t(
                    "auth.user_promoted",
                    email=updated.email,
                    previous=previous_role,
                    role=updated.role,
                ),
                bold=True,
            )

    except typer.Exit:
        raise
    except Exception as e:
        theme.bad(t("auth.promote_user_failed", error=str(e)))
        raise typer.Exit(1)


{% endif %}
@app.command(help=lazy_t("auth.help_list_users"))
def list_users() -> None:
    asyncio.run(_list_users())


async def _list_users() -> None:
    """Async implementation of list_users."""
    try:
        async with get_async_session() as session:
            user_service = UserService(session)
            users = await user_service.list_users()

            if not users:
                theme.warn(t("auth.no_users_found"))
                return

            theme.title(t("auth.found_users", count=len(users)))

            table = Table(title=t("auth.users_title"), show_header=True, header_style="bold")
            table.add_column("ID", no_wrap=True)
            table.add_column(t("auth.email_label"))
            table.add_column(t("auth.name_label"))
            table.add_column(t("auth.created_column"), style="dim")

            for user in users:
                table.add_row(
                    str(user.id),
                    user.email,
                    user.full_name or "-",
                    str(user.created_at)[:19] if user.created_at else "-",
                )

            console.print(table)

    except Exception as e:
        theme.bad(t("auth.list_users_failed", error=str(e)))
        raise typer.Exit(1)


