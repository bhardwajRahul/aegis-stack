{% if include_auth -%}
"""Background cleanup for auth tables.

Keeps the ``refresh_token`` row count bounded by deleting rows whose
``expires_at`` is older than ``REFRESH_TOKEN_RETENTION_DAYS`` (defined
in :mod:`app.services.auth.refresh_service` and shared between this
module and the rotation-path lazy sweep). Revoked rows stay visible
for that grace window so audit / forensic queries
("who-signed-out-when") still work.

This module is the canonical cleanup path when the scheduler component
is installed. Builds without a scheduler sweep opportunistically from
``RefreshService.rotate`` instead — see ``RefreshService._maybe_sweep_expired``.
"""

from datetime import UTC, datetime, timedelta

from sqlmodel import delete

from app.core.db import db_session
from app.core.log import logger
from app.models.refresh_token import RefreshToken
from app.services.auth.refresh_service import REFRESH_TOKEN_RETENTION_DAYS


def _cutoff() -> datetime:
    return datetime.now(UTC).replace(tzinfo=None) - timedelta(
        days=REFRESH_TOKEN_RETENTION_DAYS
    )


async def cleanup_expired_refresh_tokens_job() -> None:
    """Daily scheduler job: delete refresh-token rows whose
    ``expires_at`` is older than the retention window.

    Sync session (``db_session``) is used because APScheduler runs
    jobs in a worker that doesn't share the request-scoped async
    session. The query is short and indexed on ``expires_at`` would
    be a future optimisation; for now the table is small enough that
    a full scan is fine.
    """
    cutoff = _cutoff()
    with db_session() as session:
        stmt = delete(RefreshToken).where(RefreshToken.expires_at < cutoff)
        result = session.exec(stmt)  # type: ignore[call-overload]
        session.commit()
    deleted = getattr(result, "rowcount", None)
    logger.info(
        "Refresh token cleanup completed",
        extra={"deleted": deleted, "cutoff": cutoff.isoformat()},
    )
{%- endif %}
