"""Invite service for managing organization invitations."""
{% if include_auth_org %}

import secrets

from sqlmodel import select
from sqlmodel.ext.asyncio.session import AsyncSession

from app.core.config import settings
from app.models.org import (
    VALID_ORG_ROLES,
    OrgInvite,
)
from app.services.auth.membership_service import MembershipService
from app.services.auth.user_service import UserService


class InviteService:
    """Service for managing organization invitations."""

    def __init__(self, db: AsyncSession) -> None:
        self.db = db

    async def create_invite(
        self, org_id: int, email: str, role: str, invited_by: int
    ) -> OrgInvite:
        """Create an invite. If user already exists, add them directly."""
        email = email.lower()
        if role not in VALID_ORG_ROLES:
            raise ValueError(f"Invalid org role: {role}. Valid: {VALID_ORG_ROLES}")

        # Check for duplicate pending invite
        existing = await self._get_pending_invite(org_id, email)
        if existing:
            raise ValueError(f"Pending invite already exists for {email}")

        # If user already exists, add them to org immediately
        user_service = UserService(self.db)
        existing_user = await user_service.get_user_by_email(email)
        if existing_user:
            membership_service = MembershipService(self.db)
            member = await membership_service.get_member(org_id, existing_user.id)
            if member:
                raise ValueError(f"{email} is already a member of this organization")
            await membership_service.add_member(org_id, existing_user.id, role)

            # Create invite record as accepted
            invite = OrgInvite(
                organization_id=org_id,
                email=email,
                role=role,
                invited_by=invited_by,
                status="accepted",
                token=secrets.token_urlsafe(32),
            )
            self.db.add(invite)
            await self.db.commit()
            await self.db.refresh(invite)
            return invite

        # User doesn't exist — create pending invite
        invite = OrgInvite(
            organization_id=org_id,
            email=email,
            role=role,
            invited_by=invited_by,
            status="pending",
            token=secrets.token_urlsafe(32),
        )
        self.db.add(invite)
        await self.db.commit()
        await self.db.refresh(invite)
        return invite

    async def accept_pending_invites(self, email: str, user_id: int) -> int:
        """Accept all pending invites for an email. Called after registration.

        Returns the number of invites accepted.
        """
        email = email.lower()
        statement = select(OrgInvite).where(
            OrgInvite.email == email,
            OrgInvite.status == "pending",
        )
        result = await self.db.exec(statement)
        invites = list(result.all())

        if not invites:
            return 0

        membership_service = MembershipService(self.db)
        count = 0
        for invite in invites:
            await membership_service.add_member(
                invite.organization_id, user_id, invite.role
            )
            invite.status = "accepted"
            self.db.add(invite)
            count += 1

        await self.db.commit()
        return count

    async def accept_invite_by_token(
        self, token: str, caller_email: str, caller_user_id: int
    ) -> OrgInvite:
        """Accept an invite using its token.

        In 'email' mode (default), caller_email must match the invite email.
        In 'token' mode, anyone with a valid token can accept.
        """
        statement = select(OrgInvite).where(
            OrgInvite.token == token,
            OrgInvite.status == "pending",
        )
        result = await self.db.exec(statement)
        invite = result.first()

        if not invite:
            raise ValueError("Invalid or expired invite")

        # In email mode, verify the caller's email matches
        if settings.INVITE_ACCEPTANCE_MODE == "email":
            if caller_email.lower() != invite.email.lower():
                raise ValueError("Email does not match invite")

        # Add user to org
        membership_service = MembershipService(self.db)
        await membership_service.add_member(
            invite.organization_id, caller_user_id, invite.role
        )

        invite.status = "accepted"
        self.db.add(invite)
        await self.db.commit()
        await self.db.refresh(invite)
        return invite

    async def list_pending_invites(self, org_id: int) -> list[OrgInvite]:
        """List all pending invites for an organization."""
        statement = select(OrgInvite).where(
            OrgInvite.organization_id == org_id,
            OrgInvite.status == "pending",
        )
        result = await self.db.exec(statement)
        return list(result.all())

    async def _get_pending_invite(
        self, org_id: int, email: str
    ) -> OrgInvite | None:
        """Get a pending invite by org and email."""
        email = email.lower()
        statement = select(OrgInvite).where(
            OrgInvite.organization_id == org_id,
            OrgInvite.email == email,
            OrgInvite.status == "pending",
        )
        result = await self.db.exec(statement)
        return result.first()
