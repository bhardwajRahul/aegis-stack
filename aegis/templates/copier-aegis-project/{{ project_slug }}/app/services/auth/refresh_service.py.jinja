"""Refresh-token service: mint, rotate, revoke, reuse-detect.

Rotation invariants:

- Every ``rotate`` revokes the inbound row and inserts a new row
  sharing the same ``family_id``. All persistence is committed by the
  service methods themselves — callers don't need to commit.
- A refresh arriving with a row that is **already** revoked
  (``revoked_at IS NOT NULL``) is a replay. ``rotate`` revokes every
  other live row in that family and returns ``None`` so the caller
  can 401 + force re-auth.
- An expired row is treated as just "not valid"; no family revocation.
  (Expiration is normal; replay is suspicious.)

The token itself is opaque to the client: a 32-byte url-safe random
string with no embedded claims. All authorization decisions look up
the row by PK.
"""

from __future__ import annotations

import secrets
import uuid
from datetime import UTC, datetime, timedelta

from sqlmodel import select, update
from sqlmodel.ext.asyncio.session import AsyncSession

from app.core.config import settings
from app.models.refresh_token import RefreshToken


def _now() -> datetime:
    """Naive UTC ``datetime`` matching the model's column type."""
    return datetime.now(UTC).replace(tzinfo=None)


def _new_token_value() -> str:
    return secrets.token_urlsafe(32)


def _new_family_id() -> str:
    return str(uuid.uuid4())


class RefreshService:
    """DB-backed refresh-token store with rotation + reuse detection."""

    def __init__(self, db: AsyncSession) -> None:
        self.db = db

    async def mint(self, user_id: int, family_id: str | None = None) -> str:
        """Issue a new refresh token for ``user_id``.

        ``family_id`` is forwarded by ``rotate`` so descendants of a
        single sign-in share a family. Callers minting a fresh
        sign-in (login / register / OAuth callback) leave it ``None``.
        """
        token = _new_token_value()
        row = RefreshToken(
            token=token,
            user_id=user_id,
            family_id=family_id or _new_family_id(),
            expires_at=_now() + timedelta(days=settings.REFRESH_TOKEN_EXPIRE_DAYS),
        )
        self.db.add(row)
        await self.db.commit()
        return token

    async def rotate(self, token: str) -> tuple[str, int] | None:
        """Validate ``token``, revoke it, mint a successor in the same family.

        Returns ``(new_token, user_id)`` on success.
        Returns ``None`` if the token is missing, expired, or already revoked
        (the revoked-already case ALSO triggers family-wide revocation as a
        replay-attack defense).
        """
        row = await self.db.get(RefreshToken, token)
        if row is None:
            return None

        # Replay path: token was previously revoked. Nuke the family.
        if row.revoked_at is not None:
            await self.revoke_family(row.family_id)
            return None

        # Expired path: not malicious, just stale. Revoke this row, no
        # family-wide nuke.
        if row.expires_at <= _now():
            row.revoked_at = _now()
            self.db.add(row)
            await self.db.commit()
            return None

        # Happy path: revoke inbound, mint successor in the same family.
        row.revoked_at = _now()
        self.db.add(row)
        await self.db.commit()
        new_token = await self.mint(row.user_id, family_id=row.family_id)
        return new_token, row.user_id

    async def revoke(self, token: str) -> None:
        """Revoke a single refresh token.

        No-op when the token is missing or already revoked — logout
        should never 500 because the cookie is stale.
        """
        row = await self.db.get(RefreshToken, token)
        if row is None or row.revoked_at is not None:
            return
        row.revoked_at = _now()
        self.db.add(row)
        await self.db.commit()

    async def revoke_family(self, family_id: str) -> None:
        """Revoke every live row in ``family_id``.

        Used on reuse detection and (eventually) on "log out everywhere".
        """
        now = _now()
        stmt = (
            update(RefreshToken)
            .where(
                RefreshToken.family_id == family_id,  # type: ignore[arg-type]
                RefreshToken.revoked_at.is_(None),  # type: ignore[union-attr]
            )
            .values(revoked_at=now)
        )
        await self.db.exec(stmt)  # type: ignore[call-overload]
        await self.db.commit()

    async def validate(self, token: str) -> int | None:
        """Return ``user_id`` if ``token`` is live (not expired, not revoked).

        Read-only; doesn't trigger rotation or revocation. Intended for
        diagnostic paths (tests, debugging) rather than the hot refresh
        path, which should use ``rotate``.
        """
        row = await self.db.get(RefreshToken, token)
        if row is None or row.revoked_at is not None:
            return None
        if row.expires_at <= _now():
            return None
        return row.user_id

    async def list_active_for_user(self, user_id: int) -> list[RefreshToken]:
        """Return all currently-live refresh rows for a user.

        Useful for an eventual "active sessions" UI (#658 lists this as
        v2-only). Kept here so the data shape is in one place.
        """
        stmt = select(RefreshToken).where(
            RefreshToken.user_id == user_id,
            RefreshToken.revoked_at.is_(None),  # type: ignore[union-attr]
            RefreshToken.expires_at > _now(),
        )
        result = await self.db.exec(stmt)
        return list(result.all())
