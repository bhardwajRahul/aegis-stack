"""Refresh-token service: mint, rotate, revoke, reuse-detect.

Rotation invariants:

- Every ``rotate`` revokes the inbound row and inserts a new row
  sharing the same ``family_id``. All persistence is committed by the
  service methods themselves — callers don't need to commit.
- A refresh arriving with a row that is **already** revoked
  (``revoked_at IS NOT NULL``) is a replay. ``rotate`` revokes every
  other live row in that family and returns ``None`` so the caller
  can 401 + force re-auth.
- An expired row is treated as just "not valid"; no family revocation.
  (Expiration is normal; replay is suspicious.)

The token itself is opaque to the client: a 32-byte url-safe random
string with no embedded claims. All authorization decisions look up
the row by PK.
"""

from __future__ import annotations

import secrets
import uuid
from datetime import UTC, datetime, timedelta

from sqlmodel import delete, select, update
from sqlmodel.ext.asyncio.session import AsyncSession

from app.core.config import settings
from app.core.log import logger
from app.models.refresh_token import RefreshToken


# Shared with ``cleanup_jobs.cleanup_expired_refresh_tokens_job``. Rows
# older than this are deleted; revoked rows stay visible for that grace
# window so audit / forensic queries ("who-signed-out-when") still work.
REFRESH_TOKEN_RETENTION_DAYS = 7

# Minimum interval between opportunistic sweeps from ``rotate`` in
# scheduler-less builds. One hour is a reasonable upper bound on table
# growth without paying the delete cost on every rotation.
_LAZY_SWEEP_INTERVAL = timedelta(hours=1)


def _now() -> datetime:
    """Naive UTC ``datetime`` matching the model's column type."""
    return datetime.now(UTC).replace(tzinfo=None)


def _new_token_value() -> str:
    return secrets.token_urlsafe(32)


def _new_family_id() -> str:
    return str(uuid.uuid4())


class RefreshService:
    """DB-backed refresh-token store with rotation + reuse detection."""

    # Class-level cache for the lazy-sweep gate so the interval is
    # shared across per-request service instances. ``None`` means the
    # sweep has never run; the first eligible rotation primes it.
    _last_sweep_at: datetime | None = None

    def __init__(self, db: AsyncSession) -> None:
        self.db = db

    async def mint(
        self,
        user_id: int,
        family_id: str | None = None,
        *,
        source: str | None = None,
        user_agent: str | None = None,
        ip: str | None = None,
        last_used_at: datetime | None = None,
    ) -> str:
        """Issue a new refresh token for ``user_id``.

        ``family_id`` is forwarded by ``rotate`` so descendants of a
        single sign-in share a family. Callers minting a fresh
        sign-in (login / register / OAuth callback) leave it ``None``.

        ``source`` / ``user_agent`` / ``ip`` populate the session-list
        UI (#633). They're all optional so paths without request
        context (tests, internal flows) still work.
        """
        token = _new_token_value()
        row = RefreshToken(
            token=token,
            user_id=user_id,
            family_id=family_id or _new_family_id(),
            expires_at=_now() + timedelta(days=settings.REFRESH_TOKEN_EXPIRE_DAYS),
            source=source,
            user_agent=user_agent,
            ip=ip,
            last_used_at=last_used_at,
        )
        self.db.add(row)
        await self.db.commit()
        return token

    async def rotate(
        self,
        token: str,
        *,
        user_agent: str | None = None,
        ip: str | None = None,
    ) -> tuple[str, int] | None:
        """Validate ``token``, revoke it, mint a successor in the same family.

        Returns ``(new_token, user_id)`` on success.
        Returns ``None`` if the token is missing, expired, or already revoked
        (the revoked-already case ALSO triggers family-wide revocation as a
        replay-attack defense).

        ``user_agent`` / ``ip`` come from the rotating request and land
        on the new row so the active-sessions UI can show the most
        recent device fingerprint. ``source`` is sticky — copied
        forward from the parent row — because the way a session was
        originally created doesn't change on rotation.
        """
        row = await self.db.get(RefreshToken, token)
        if row is None:
            return None

        # Replay path: token was previously revoked. Nuke the family.
        if row.revoked_at is not None:
            await self.revoke_family(row.family_id)
            return None

        # Expired path: not malicious, just stale. Revoke this row, no
        # family-wide nuke.
        if row.expires_at <= _now():
            row.revoked_at = _now()
            self.db.add(row)
            await self.db.commit()
            return None

        # Happy path: revoke inbound, mint successor in the same family.
        row.revoked_at = _now()
        self.db.add(row)
        await self.db.commit()
        new_token = await self.mint(
            row.user_id,
            family_id=row.family_id,
            source=row.source,
            user_agent=user_agent,
            ip=ip,
            last_used_at=_now(),
        )
{% if not include_scheduler %}
        # No scheduler component — sweep expired rows opportunistically
        # from the rotation path. The scheduled job (see
        # ``cleanup_jobs.cleanup_expired_refresh_tokens_job``) owns this
        # when the scheduler IS installed.
        await self._maybe_sweep_expired()
{% endif %}
        return new_token, row.user_id

{% if not include_scheduler %}
    async def _maybe_sweep_expired(self) -> None:
        """Opportunistic cleanup for builds without a scheduler.

        ``cleanup_expired_refresh_tokens_job`` is the canonical path
        when the scheduler component is installed. In its absence we
        ride the refresh hot path: at most one delete every hour,
        guarded by a class-level timestamp so concurrent rotations
        don't pile up the same DELETE. Matches the retention window
        of the scheduled job.
        """
        now = _now()
        last = RefreshService._last_sweep_at
        if last is not None and (now - last) < _LAZY_SWEEP_INTERVAL:
            return
        RefreshService._last_sweep_at = now
        cutoff = now - timedelta(days=REFRESH_TOKEN_RETENTION_DAYS)
        try:
            stmt = delete(RefreshToken).where(
                RefreshToken.expires_at < cutoff,
            )
            await self.db.exec(stmt)  # type: ignore[call-overload]
            await self.db.commit()
        except Exception:  # pragma: no cover — sweep must never break rotation
            logger.exception("Lazy refresh-token sweep failed; will retry next interval")

{% endif %}
    async def revoke(self, token: str) -> None:
        """Revoke a single refresh token.

        No-op when the token is missing or already revoked — logout
        should never 500 because the cookie is stale.
        """
        row = await self.db.get(RefreshToken, token)
        if row is None or row.revoked_at is not None:
            return
        row.revoked_at = _now()
        self.db.add(row)
        await self.db.commit()

    async def revoke_family(self, family_id: str) -> None:
        """Revoke every live row in ``family_id``.

        Used on reuse detection and (eventually) on "log out everywhere".
        """
        now = _now()
        stmt = (
            update(RefreshToken)
            .where(
                RefreshToken.family_id == family_id,  # type: ignore[arg-type]
                RefreshToken.revoked_at.is_(None),  # type: ignore[union-attr]
            )
            .values(revoked_at=now)
        )
        await self.db.exec(stmt)  # type: ignore[call-overload]
        await self.db.commit()

    async def revoke_all_for_user(self, user_id: int) -> None:
        """Mark every live refresh token for ``user_id`` revoked.

        Single UPDATE, no internal commit. The caller composes this into
        a larger transaction (password reset, account close) so the
        revoke and the cause-of-revoke land all-or-nothing.

        For interactive "sign out everywhere else" flows that own their
        own transaction, keep using :meth:`revoke_other_sessions`.
        """
        now = _now()
        stmt = (
            update(RefreshToken)
            .where(
                RefreshToken.user_id == user_id,
                RefreshToken.revoked_at.is_(None),  # type: ignore[union-attr]
            )
            .values(revoked_at=now)
        )
        await self.db.exec(stmt)  # type: ignore[call-overload]

    async def validate(self, token: str) -> int | None:
        """Return ``user_id`` if ``token`` is live (not expired, not revoked).

        Read-only; doesn't trigger rotation or revocation. Intended for
        diagnostic paths (tests, debugging) rather than the hot refresh
        path, which should use ``rotate``.
        """
        row = await self.db.get(RefreshToken, token)
        if row is None or row.revoked_at is not None:
            return None
        if row.expires_at <= _now():
            return None
        return row.user_id

    async def list_active_for_user(self, user_id: int) -> list[RefreshToken]:
        """Return all currently-live refresh rows for a user.

        Returns every row (not collapsed by family). Use
        :meth:`list_sessions` for the session-shaped view consumed by
        the active-sessions UI.
        """
        stmt = select(RefreshToken).where(
            RefreshToken.user_id == user_id,
            RefreshToken.revoked_at.is_(None),  # type: ignore[union-attr]
            RefreshToken.expires_at > _now(),
        )
        result = await self.db.exec(stmt)
        return list(result.all())

    async def list_sessions(self, user_id: int) -> list[RefreshToken]:
        """Return one live row per ``family_id`` — i.e. one row per
        active device session.

        Picks the most recently created live row in each family so the
        UA/IP/last_used_at reflect the latest rotation. Ordered by
        ``last_used_at`` desc (nulls fall back to ``created_at``).
        """
        rows = await self.list_active_for_user(user_id)
        by_family: dict[str, RefreshToken] = {}
        for row in rows:
            current = by_family.get(row.family_id)
            if current is None or row.created_at > current.created_at:
                by_family[row.family_id] = row

        def _sort_key(r: RefreshToken) -> datetime:
            return r.last_used_at or r.created_at

        return sorted(by_family.values(), key=_sort_key, reverse=True)

    async def revoke_session(self, family_id: str, user_id: int) -> bool:
        """Revoke an entire session by ``family_id``, but only if it
        belongs to ``user_id``.

        Returns ``True`` if a live row was found and revoked, ``False``
        if no such row (wrong user, unknown family, or already revoked).
        """
        stmt = select(RefreshToken).where(
            RefreshToken.family_id == family_id,  # type: ignore[arg-type]
            RefreshToken.user_id == user_id,
            RefreshToken.revoked_at.is_(None),  # type: ignore[union-attr]
        )
        result = await self.db.exec(stmt)
        live_rows = list(result.all())
        if not live_rows:
            return False
        await self.revoke_family(family_id)
        return True

    async def revoke_other_sessions(
        self, keep_family_id: str, user_id: int
    ) -> int:
        """Revoke every live row for ``user_id`` except those in
        ``keep_family_id``. Returns the count of *families* revoked
        (one increment per affected session, not per row)."""
        rows = await self.list_active_for_user(user_id)
        families: set[str] = {
            r.family_id for r in rows if r.family_id != keep_family_id
        }
        for fid in families:
            await self.revoke_family(fid)
        return len(families)
{%- endif %}
