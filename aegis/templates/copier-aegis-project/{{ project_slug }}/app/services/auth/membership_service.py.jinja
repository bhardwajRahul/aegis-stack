"""Membership service for managing organization members."""
{% if include_auth_org %}

from datetime import UTC, datetime

from sqlmodel import select
from sqlmodel.ext.asyncio.session import AsyncSession

from app.models.user import User
from app.models.org import (
    VALID_ORG_ROLES,
    Organization,
    OrganizationMember,
)


class MembershipService:
    """Service for managing organization memberships."""

    def __init__(self, db: AsyncSession) -> None:
        self.db = db

    async def add_member(
        self, org_id: int, user_id: int, role: str = "member"
    ) -> OrganizationMember:
        """Add a user to an organization."""
        if role not in VALID_ORG_ROLES:
            raise ValueError(f"Invalid org role: {role}. Valid: {VALID_ORG_ROLES}")
        member = OrganizationMember(
            organization_id=org_id,
            user_id=user_id,
            role=role,
            joined_at=datetime.now(UTC).replace(tzinfo=None),
        )
        self.db.add(member)
        await self.db.commit()
        await self.db.refresh(member)
        return member

    async def remove_member(self, org_id: int, user_id: int) -> bool:
        """Remove a user from an organization."""
        member = await self.get_member(org_id, user_id)
        if not member:
            return False
        await self.db.delete(member)
        await self.db.commit()
        return True

    async def get_member(
        self, org_id: int, user_id: int
    ) -> OrganizationMember | None:
        """Get a specific membership."""
        statement = select(OrganizationMember).where(
            OrganizationMember.organization_id == org_id,
            OrganizationMember.user_id == user_id,
        )
        result = await self.db.exec(statement)
        return result.first()

    async def update_member_role(
        self, org_id: int, user_id: int, role: str
    ) -> OrganizationMember | None:
        """Update a member's role within an organization."""
        if role not in VALID_ORG_ROLES:
            raise ValueError(f"Invalid org role: {role}. Valid: {VALID_ORG_ROLES}")
        member = await self.get_member(org_id, user_id)
        if not member:
            return None
        member.role = role
        self.db.add(member)
        await self.db.commit()
        await self.db.refresh(member)
        return member

    async def transfer_ownership(
        self, org_id: int, current_owner_id: int, new_owner_id: int
    ) -> None:
        """Transfer org ownership. New owner must be an existing member."""
        new_owner = await self.get_member(org_id, new_owner_id)
        if not new_owner:
            raise ValueError("Target user is not a member of this organization")

        current_owner = await self.get_member(org_id, current_owner_id)
        if not current_owner:
            raise ValueError("Current owner membership not found")

        new_owner.role = "owner"
        current_owner.role = "admin"
        self.db.add(new_owner)
        self.db.add(current_owner)
        await self.db.commit()

    async def bulk_add_members(
        self,
        org_id: int,
        user_ids: list[int],
        role: str = "member",
    ) -> list[OrganizationMember]:
        """Add multiple users to an organization in a single transaction.

        Fetches existing members for the org once, diffs in Python, then
        bulk-inserts. Scales to any input size — no IN clause.
        Returns only newly added members.
        """
        if role not in VALID_ORG_ROLES:
            raise ValueError(f"Invalid org role: {role}. Valid: {VALID_ORG_ROLES}")

        # One query: all existing member user_ids for this org
        statement = select(OrganizationMember.user_id).where(
            OrganizationMember.organization_id == org_id
        )
        result = await self.db.exec(statement)
        existing_ids = set(result.all())

        # De-duplicate input, then diff against existing — O(n)
        new_ids = [uid for uid in dict.fromkeys(user_ids) if uid not in existing_ids]

        now = datetime.now(UTC).replace(tzinfo=None)
        added: list[OrganizationMember] = []
        for uid in new_ids:
            member = OrganizationMember(
                organization_id=org_id,
                user_id=uid,
                role=role,
                joined_at=now,
            )
            self.db.add(member)
            added.append(member)

        if added:
            await self.db.flush()
            await self.db.commit()

        return added

    async def list_org_members(self, org_id: int) -> list[OrganizationMember]:
        """List all members of an organization."""
        statement = select(OrganizationMember).where(
            OrganizationMember.organization_id == org_id
        )
        result = await self.db.exec(statement)
        return list(result.all())

    async def list_org_members_with_details(
        self, org_id: int
    ) -> list[dict[str, int | str | None]]:
        """List org members with user details (email, name). Single JOIN query."""
        statement = (
            select(
                OrganizationMember.user_id,
                User.email,
                User.full_name,
                OrganizationMember.role,
                OrganizationMember.joined_at,
            )
            .join(User, OrganizationMember.user_id == User.id)
            .where(OrganizationMember.organization_id == org_id)
        )
        result = await self.db.exec(statement)
        return [
            {
                "user_id": row.user_id,
                "email": row.email,
                "full_name": row.full_name,
                "role": row.role,
                "joined_at": row.joined_at,
            }
            for row in result.all()
        ]

    async def list_user_orgs(self, user_id: int) -> list[Organization]:
        """List all organizations a user belongs to."""
        statement = (
            select(Organization)
            .join(
                OrganizationMember,
                OrganizationMember.organization_id == Organization.id,
            )
            .where(OrganizationMember.user_id == user_id)
        )
        result = await self.db.exec(statement)
        return list(result.all())

    async def list_all_memberships(
        self,
    ) -> list[dict[str, int | str]]:
        """List all memberships with org names (single JOIN query)."""
        statement = select(
            OrganizationMember.user_id,
            Organization.name.label("org_name"),
            Organization.slug.label("org_slug"),
            OrganizationMember.role,
        ).join(Organization, OrganizationMember.organization_id == Organization.id)
        result = await self.db.exec(statement)
        return [
            {
                "user_id": row.user_id,
                "org_name": row.org_name,
                "org_slug": row.org_slug,
                "role": row.role,
            }
            for row in result.all()
        ]
