async def collect_all_job() -> None:
    """Scheduled job: run all enabled collectors.
    {% if insights_per_user %}

    Multi-tenant: dispatches each per-source job which in turn iterates
    its own project list. A project that only has GitHub configured is
    silently skipped by the PyPI job, etc.
    {% endif %}
    """
    logger.info("Running scheduled collection for all enabled sources")
    {% if insights_per_user -%}
    {% if insights_github -%}
    await collect_github_traffic_job()
    await collect_github_stars_job()
    await collect_github_events_job()
    {%- endif %}
    {% if insights_pypi -%}
    await collect_pypi_job()
    {%- endif %}
    {% if insights_plausible -%}
    await collect_plausible_job()
    {%- endif %}
    {% else -%}
    async with get_async_session() as session:
        service = CollectorService(session)
        results = await service.collect_all()
        for source_key, result in results.items():
            if result.success:
                logger.info(
                    "%s: %d written, %d skipped",
                    source_key,
                    result.rows_written,
                    result.rows_skipped,
                )
            else:
                logger.error("%s failed: %s", source_key, result.error)
    {%- endif %}
