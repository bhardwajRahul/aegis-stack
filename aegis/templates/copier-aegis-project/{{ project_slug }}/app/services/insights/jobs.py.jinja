"""
Scheduler jobs for insight data collection.

Each enabled source gets a scheduled job that runs its collector
at the configured interval.
{% if insights_per_user %}

Multi-tenant when ``auth`` is on: each job iterates over every project
that has the relevant source configured (e.g. ``project.github_repo``
set for the GitHub jobs) and runs one ``CollectorService`` per project.
A project with no source set is silently skipped — collectors are only
useful when their config is present.
{% endif %}
"""

import logging

from app.core.db import get_async_session

from .collector_service import CollectorService
from .constants import SourceKeys
{% if insights_per_user -%}
from .project_service import ProjectService
{%- endif %}

logger = logging.getLogger(__name__)


async def _run_one(
    session,
    source_key: str,
    {% if insights_per_user -%}
    project=None,
    {%- endif %}
) -> None:
    """Run a single source collection and log the outcome.

    Used by all per-source job entry points so logging and error handling
    stay consistent across sources.
    """
    {% if insights_per_user -%}
    service = CollectorService(session, project=project)
    suffix = f" (project={project.slug})" if project is not None else ""
    {% else -%}
    service = CollectorService(session)
    suffix = ""
    {%- endif %}
    result = await service.collect_source(source_key)
    if result.success:
        logger.info(
            "%s%s: %d written, %d skipped",
            source_key,
            suffix,
            result.rows_written,
            result.rows_skipped,
        )
    else:
        logger.error("%s%s collection failed: %s", source_key, suffix, result.error)


{% if insights_github %}


async def collect_github_traffic_job() -> None:
    """Scheduled job: collect GitHub traffic data."""
    logger.info("Running scheduled GitHub traffic collection")
    async with get_async_session() as session:
        {% if insights_per_user -%}
        projects = await ProjectService(session).list_with_github()
        if not projects:
            logger.info("No projects with GitHub configured; skipping")
            return
        for project in projects:
            await _run_one(session, SourceKeys.GITHUB_TRAFFIC, project=project)
        {% else -%}
        await _run_one(session, SourceKeys.GITHUB_TRAFFIC)
        {%- endif %}


