"""
Insight service database models.

Six tables:
- InsightSource: Lookup table for data sources (GitHub, PyPI, Plausible, Reddit)
- InsightMetricType: Lookup table for metric types, FK to source
- InsightMetric: Time-series data, FK to metric type, JSONB metadata
- InsightRecord: All-time records/milestones per metric type
- InsightEvent: Contextual markers (releases, posts, external events)
- Goal: User-defined targets for metrics (absolute / delta / rate)
"""

from datetime import UTC, date, datetime
from enum import StrEnum
from typing import Any

{% if insights_per_user %}
# InsightEvent declares a FK to the `user` table (see `created_by_user_id`
# below). Importing User here ensures its SQLModel metadata is registered
# before any code in a non-webserver process — e.g. the scheduler — tries
# to flush an InsightEvent. Without this, SQLAlchemy raises
# NoReferencedTableError("user") because the scheduler's import chain
# never touches the auth module that otherwise pulls User in.
# noqa is because the symbol is only referenced by a FK string at commit
# time, not by Python code here.
from app.models.user import User  # noqa: F401
{% endif %}
from sqlalchemy import JSON, CheckConstraint, Column, Index, String, UniqueConstraint
from sqlmodel import Field, Relationship, SQLModel

{% if insights_per_user %}
# ---------------------------------------------------------------------------
# Tenancy: Project
# ---------------------------------------------------------------------------


class Project(SQLModel, table=True):
    """A user's tracked project — one repo / package / site bundle.

    The unit of multi-tenancy for the insights service: every metric,
    event, and goal carries a non-null FK to a Project row, and reads
    are scoped by ``current_user.id == project.owner_user_id``. One
    user can own many projects (e.g. a maintainer tracking several of
    their repos); one project belongs to exactly one user in v1
    (org-shared projects are v2).

    Source-credential columns (``github_token``, ``plausible_api_key``)
    are encrypted at rest via ``app.core.encryption``. The encrypt /
    decrypt happens in ``ProjectService``, so the columns hold ciphertext
    and reads return plaintext to the rest of the app.

    The slug is the URL handle: ``/insights/projects/<slug>/...``. It's
    unique per-owner (a user can't have two projects with the same
    slug, but two different users can each have a project named
    ``my-thing``). The composite uniqueness handles that.
    """

    __tablename__ = "project"
    __table_args__ = (
        # owner_user_id index is auto-generated by ``index=True`` on the
        # field below — no explicit Index needed here, otherwise SQLite
        # raises "index already exists" at create_all time.
        UniqueConstraint("owner_user_id", "slug", name="uq_project_owner_slug"),
    )

    id: int | None = Field(default=None, primary_key=True)
    slug: str = Field(max_length=64, index=True)
    name: str = Field(max_length=128)
    owner_user_id: int = Field(foreign_key="user.id", index=True)

    # Source configuration. Each is optional — a project may track
    # only GitHub, only PyPI, etc. A project with no sources set is
    # valid (placeholder); collectors simply skip it.
    github_owner: str | None = Field(default=None, max_length=64)
    github_repo: str | None = Field(default=None, max_length=128)
    # Encrypted at rest via ``ProjectService``.
    github_token: str | None = Field(default=None, max_length=512)

    pypi_package: str | None = Field(default=None, max_length=128)

    plausible_site: str | None = Field(default=None, max_length=256)
    # Encrypted at rest.
    plausible_api_key: str | None = Field(default=None, max_length=512)

    reddit_subreddits: str | None = Field(default=None, max_length=256)

    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )
    updated_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

    # Cascade-delete: dropping a project drops every metric/event/goal
    # row that belongs to it. ``passive_deletes=True`` lets the DB do
    # the cascade rather than SQLAlchemy loading every child first.
    metrics: list["InsightMetric"] = Relationship(
        back_populates="project",
        sa_relationship_kwargs={
            "cascade": "all, delete-orphan",
            "passive_deletes": True,
        },
    )
    events: list["InsightEvent"] = Relationship(
        back_populates="project",
        sa_relationship_kwargs={
            "cascade": "all, delete-orphan",
            "passive_deletes": True,
        },
    )
    goals: list["Goal"] = Relationship(
        back_populates="project",
        sa_relationship_kwargs={
            "cascade": "all, delete-orphan",
            "passive_deletes": True,
        },
    )
{% endif %}


# ---------------------------------------------------------------------------
# Lookup: InsightSource
# ---------------------------------------------------------------------------


class InsightSource(SQLModel, table=True):
    """Data source for insight collection (e.g., GitHub, PyPI, Plausible)."""

    __tablename__ = "insight_source"

    id: int | None = Field(default=None, primary_key=True)
    key: str = Field(unique=True, index=True, max_length=64)
    display_name: str = Field(max_length=128)
    collection_interval_hours: int | None = Field(default=None)
    requires_auth: bool = Field(default=False)
    enabled: bool = Field(default=True)
    last_collected_at: datetime | None = Field(default=None)
    metadata_: dict[str, Any] = Field(
        default_factory=dict, sa_column=Column("metadata", JSON)
    )
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

    # Relationships
    metric_types: list["InsightMetricType"] = Relationship(back_populates="source")  # noqa: F821


# ---------------------------------------------------------------------------
# Lookup: InsightMetricType
# ---------------------------------------------------------------------------


class InsightMetricType(SQLModel, table=True):
    """Type of metric collected by a source (e.g., clones, unique_cloners)."""

    __tablename__ = "insight_metric_type"
    __table_args__ = (
        UniqueConstraint("source_id", "key", name="uq_metric_type_source_key"),
    )

    id: int | None = Field(default=None, primary_key=True)
    source_id: int = Field(foreign_key="insight_source.id", index=True)
    key: str = Field(index=True, max_length=64)
    display_name: str = Field(max_length=128)
    unit: str = Field(max_length=32)  # count, seconds, percentage, ratio, json
    metadata_: dict[str, Any] = Field(
        default_factory=dict, sa_column=Column("metadata", JSON)
    )
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

    # Relationships
    source: InsightSource = Relationship(back_populates="metric_types")
    metrics: list["InsightMetric"] = Relationship(back_populates="metric_type")  # noqa: F821
    records: list["InsightRecord"] = Relationship(back_populates="metric_type")  # noqa: F821


# ---------------------------------------------------------------------------
# Time-series: InsightMetric
# ---------------------------------------------------------------------------


class InsightMetric(SQLModel, table=True):
    """Single metric data point. The core time-series table.

    {% if insights_per_user -%}
    Multi-tenant: every row carries a non-null ``project_id``. Reads
    are always filtered by it so cross-user data leakage is prevented
    structurally rather than via application-layer guard rails.
    {%- endif %}
    """

    __tablename__ = "insight_metric"
    __table_args__ = (
        # THE primary query pattern: "get clones for last 14 days"
        Index("ix_insight_metric_type_date", "metric_type_id", "date"),
        # Secondary: "all metrics for this date"
        Index("ix_insight_metric_date", "date"),
        {% if insights_per_user -%}
        # The dashboard's per-project query: "give me everything for
        # project X over the last N days." Compound index keeps it
        # under a single B-tree probe.
        Index("ix_insight_metric_project_date", "project_id", "date"),
        {%- endif %}
    )

    id: int | None = Field(default=None, primary_key=True)
    date: datetime = Field(index=False)  # Covered by compound indexes above
    metric_type_id: int = Field(foreign_key="insight_metric_type.id", index=True)
    {% if insights_per_user -%}
    project_id: int = Field(
        foreign_key="project.id",
        index=True,
        sa_column_kwargs={"nullable": False},
    )
    {%- endif %}
    value: float = Field(default=0.0)
    period: str = Field(max_length=32)  # daily, cumulative, snapshot, event
    metadata_: dict[str, Any] = Field(
        default_factory=dict, sa_column=Column("metadata", JSON)
    )
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

    # Relationships
    metric_type: InsightMetricType = Relationship(back_populates="metrics")
    {% if insights_per_user -%}
    project: "Project" = Relationship(back_populates="metrics")
    {%- endif %}


# ---------------------------------------------------------------------------
# Records: InsightRecord
# ---------------------------------------------------------------------------


class InsightRecord(SQLModel, table=True):
    """All-time record for a metric type. Updated in place when broken."""

    __tablename__ = "insight_record"

    id: int | None = Field(default=None, primary_key=True)
    metric_type_id: int = Field(
        foreign_key="insight_metric_type.id", unique=True, index=True
    )
    value: float = Field(default=0.0)
    date_achieved: datetime
    previous_value: float | None = Field(default=None)
    previous_date: datetime | None = Field(default=None)
    context: str | None = Field(default=None, max_length=512)
    metadata_: dict[str, Any] = Field(
        default_factory=dict, sa_column=Column("metadata", JSON)
    )
    updated_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

    # Relationships
    metric_type: InsightMetricType = Relationship(back_populates="records")


# ---------------------------------------------------------------------------
# Goals: enums + Goal
# ---------------------------------------------------------------------------


class GoalKind(StrEnum):
    """How a goal is evaluated.

    - ABSOLUTE: reach `target_value` for `metric_key` by `target_date`.
    - DELTA:    gain `target_value` over the `window_days` ending at `target_date`.
    - RATE:     sustain `target_value` per `window_days` (rolling; target_date optional).
    """

    ABSOLUTE = "absolute"
    DELTA = "delta"
    RATE = "rate"


class GoalStatus(StrEnum):
    """Lifecycle state for a goal."""

    ACTIVE = "active"
    ACHIEVED = "achieved"
    ABANDONED = "abandoned"


class GoalMetric(StrEnum):
    """User-facing metric keys a goal can track.

    Values are `source.metric` pairs resolved at query time to the underlying
    (InsightSource, InsightMetricType) tuple by the goal service. Kept separate
    from `MetricKeys` / `SourceKeys` so the goal surface stays narrow — we only
    expose metrics that make sense as goal targets (countable, monotonic or
    summable), not every collector field.
    """

    # GitHub
    GITHUB_STARS = "github.stars"
    GITHUB_CLONES = "github.clones"
    GITHUB_UNIQUE_CLONERS = "github.unique_cloners"
    GITHUB_VIEWS = "github.views"
    GITHUB_UNIQUE_VISITORS = "github.unique_visitors"
    GITHUB_FORKS = "github.forks"
    GITHUB_RELEASES = "github.releases"

    # PyPI
    PYPI_DOWNLOADS = "pypi.downloads"

    # Docs (Plausible)
    DOCS_VISITORS = "docs.visitors"
    DOCS_PAGEVIEWS = "docs.pageviews"


# ---------------------------------------------------------------------------
# Goals: Goal
# ---------------------------------------------------------------------------

{% if insights_per_user %}

class Goal(SQLModel, table=True):
    """User-defined target for an insight metric.

    Progress is *derived* from the existing time-series in `insight_metric` —
    no snapshot table. Scoping via `project_id` (FK to Project): a goal is
    always pinned to one project and shows up in that project's view.

    In v1, ``user_id == project.owner_user_id`` for newly-created goals.
    Migrated rows from the pre-multi-tenant era may carry user_ids that
    don't match the seed-project owner; that's preserved as-is and gets
    normalized in v2 (org-sharing) when goals can legitimately belong
    to a different user than the project owner.
    """

    __tablename__ = "insight_goal"
    __table_args__ = (
        Index("ix_insight_goal_user_status", "user_id", "status"),
        Index("ix_insight_goal_project_metric", "project_id", "metric_key"),
        # Enum-style guardrails. Project convention: VARCHAR + CHECK
        # constraint instead of native PG enum types so adding/removing
        # values is a simple migration on both SQLite and Postgres.
        CheckConstraint(
            "kind IN ('absolute', 'delta', 'rate')",
            name="ck_insight_goal_kind",
        ),
        CheckConstraint(
            "status IN ('active', 'achieved', 'abandoned')",
            name="ck_insight_goal_status",
        ),
        CheckConstraint(
            "metric_key IN ("
            "'github.stars', 'github.clones', 'github.unique_cloners', "
            "'github.views', 'github.unique_visitors', 'github.forks', "
            "'github.releases', 'pypi.downloads', 'docs.visitors', "
            "'docs.pageviews'"
            ")",
            name="ck_insight_goal_metric_key",
        ),
    )

    id: int | None = Field(default=None, primary_key=True)
    user_id: int = Field(foreign_key="user.id", index=True)

    # Multi-tenant FK: every goal belongs to exactly one project.
    project_id: int = Field(
        foreign_key="project.id",
        index=True,
        sa_column_kwargs={"nullable": False},
    )

    metric_key: GoalMetric = Field(
        sa_column=Column("metric_key", String(64), nullable=False, index=True)
    )
    kind: GoalKind = Field(sa_column=Column("kind", String(16), nullable=False))
    target_value: float

    # Required for DELTA and RATE; ignored for ABSOLUTE.
    window_days: int | None = Field(default=None)
    # Required for ABSOLUTE; optional deadline for DELTA/RATE.
    target_date: date | None = Field(default=None)

    status: GoalStatus = Field(
        default=GoalStatus.ACTIVE,
        sa_column=Column(
            "status", String(16), nullable=False, default=GoalStatus.ACTIVE.value
        ),
    )

    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )
    updated_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

    # Cascade-on-delete: dropping a project drops every goal under it.
    project: "Project" = Relationship(back_populates="goals")
{% endif %}{# insights_per_user #}


# ---------------------------------------------------------------------------
# Events: InsightEvent
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# Event display labels — single source of truth for turning `event_type`
# strings (collector output + UserEventType enum values) into human-friendly
# labels. Used by the API to attach `display_type` to each event response so
# the UI never has to handle snake_case.
# ---------------------------------------------------------------------------

EVENT_TYPE_LABELS: dict[str, str] = {
    # User-created types (mirrors UserEventType)
    "note": "Note",
    "milestone": "Milestone",
    "release": "Release",
    "announcement": "Announcement",
    "external": "External",
    # Collector-emitted types
    "reddit_post": "Reddit post",
    "star": "Star",
    "fork": "Fork",
    "feature": "Feature",
    "localization": "Localization",
    "anomaly_github": "GitHub anomaly",
    "milestone_github": "GitHub milestone",
    "milestone_pypi": "PyPI milestone",
    "milestone_plausible": "Plausible milestone",
}


def event_type_display(event_type: str) -> str:
    """Friendly label for an event_type. Unknown types get title-cased
    with underscores→spaces as a sensible fallback."""
    if event_type in EVENT_TYPE_LABELS:
        return EVENT_TYPE_LABELS[event_type]
    return event_type.replace("_", " ").title()


class UserEventType(StrEnum):
    """Event types the user can select when creating an event in the UI/CLI.

    Collector-origin events keep free-form `event_type` strings (driven by
    collector code); this enum only constrains user-created rows, validated
    at the service/API boundary.
    """

    NOTE = "note"
    MILESTONE = "milestone"
    RELEASE = "release"
    ANNOUNCEMENT = "announcement"
    EXTERNAL = "external"


class EventOrigin(StrEnum):
    """Where an event came from — distinguishes collector output from user-
    created annotations so collector cleanups don't wipe hand-curated entries
    and the UI only exposes `user` rows for editing."""

    COLLECTOR = "collector"
    USER = "user"


class InsightEvent(SQLModel, table=True):
    """Contextual marker explaining why a metric changed.

    Rows come from two origins: collectors emit `COLLECTOR`-origin events
    automatically, and authed users create `USER`-origin events via the
    events API / CLI. Collector queries filter on origin to stay insulated
    from hand-curated rows.
    """

    __tablename__ = "insight_event"
    __table_args__ = (
        Index("ix_insight_event_date", "date"),
        Index("ix_insight_event_type_date", "event_type", "date"),
        Index("ix_insight_event_origin_date", "origin", "date"),
        {% if insights_per_user -%}
        # Per-project timeline query: dashboard activity feed for one project.
        Index("ix_insight_event_project_date", "project_id", "date"),
        {%- endif %}
        CheckConstraint(
            "origin IN ('collector', 'user')",
            name="ck_insight_event_origin",
        ),
    )

    id: int | None = Field(default=None, primary_key=True)
    date: datetime
    event_type: str = Field(
        max_length=64, sa_column=Column("event_type", String(64), nullable=False)
    )  # reddit_post, release, localization, external (collector); UserEventType (user)
    description: str = Field(max_length=1024)
    metadata_: dict[str, Any] = Field(
        default_factory=dict, sa_column=Column("metadata", JSON)
    )
    # Stored as a plain str on the Pydantic side (column is also plain
    # String(16)) — typing the field as `EventOrigin` causes Pydantic to
    # emit `PydanticSerializationUnexpectedValue` for every row in the
    # response, since SQLAlchemy hands back a raw str on hydration. The
    # `EventOrigin` class is kept above purely as a constants holder and
    # the value space is enforced at the DB level by `ck_insight_event_origin`.
    origin: str = Field(
        default=EventOrigin.COLLECTOR.value,
        sa_column=Column(
            "origin",
            String(16),
            nullable=False,
            default=EventOrigin.COLLECTOR.value,
            index=True,
        ),
    )
{% if insights_per_user %}
    project_id: int = Field(
        foreign_key="project.id",
        index=True,
        sa_column_kwargs={"nullable": False},
    )
    created_by_user_id: int | None = Field(
        default=None, foreign_key="user.id", index=True
    )
{% endif %}
    created_at: datetime = Field(
        default_factory=lambda: datetime.now(UTC).replace(tzinfo=None)
    )

{% if insights_per_user %}
    # Relationship back to owning project for cascade-on-delete.
    project: "Project" = Relationship(back_populates="events")
{% endif %}
