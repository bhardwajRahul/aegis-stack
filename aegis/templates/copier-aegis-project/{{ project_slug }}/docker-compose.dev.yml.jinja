# Development overrides
# Usage: docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile dev up
#
# Adds:
#   - Code volume mounts for hot-reload
#   - Debug ports for direct service access

services:
  webserver:
    volumes:
      - .:/code
    ports:
      # Host port auto-selected by `make serve` (WEBSERVER_HOST_PORT);
      # falls back to PORT for a raw `docker compose up`.
      - "${WEBSERVER_HOST_PORT:-${PORT:-8000}}:${PORT:-8000}"
{%- if include_finance and finance_plaid %}
    environment:
      - PLAID_TUNNEL_METRICS_URL=http://plaid-tunnel:20241
{%- endif %}
{%- if include_ingress and ingress_tls %}
    labels:
      # Dev router (HTTP, localhost — no TLS)
      - "traefik.http.routers.webserver-dev.rule=Host(`localhost`) || Host(`127.0.0.1`)"
      - "traefik.http.routers.webserver-dev.entrypoints=web"
      - "traefik.http.routers.webserver-dev.service=webserver"
      # Admin paths in dev
      - "traefik.http.routers.webserver-admin.rule=PathPrefix(`/dashboard`) || PathPrefix(`/docs`) || PathPrefix(`/redoc`) || PathPrefix(`/openapi.json`)"
      - "traefik.http.routers.webserver-admin.entrypoints=web"
      - "traefik.http.routers.webserver-admin.service=webserver"
      - "traefik.http.routers.webserver-admin.middlewares=admin-ipallowlist"
      - "traefik.http.middlewares.admin-ipallowlist.ipallowlist.sourcerange=${ADMIN_IP_ALLOWLIST:-0.0.0.0/0}"
{%- endif %}
{%- if include_scheduler %}

  scheduler:
    volumes:
      - .:/code
{%- endif %}
{%- if include_worker %}

  worker-load-test:
    volumes:
      - .:/code

  worker-system:
    volumes:
      - .:/code
{%- endif %}
{%- if include_redis %}

  redis:
    ports:
      # Host port auto-selected by `make serve` (REDIS_HOST_PORT). The
      # container still listens on 6379 for in-network clients.
      - "${REDIS_HOST_PORT:-6379}:6379"
{%- endif %}
{%- if database_engine == "postgres" %}

  postgres:
    ports:
      # Host port auto-selected by `make serve` (POSTGRES_HOST_PORT). The
      # container still listens on 5432 for in-network clients.
      - "${POSTGRES_HOST_PORT:-5432}:5432"
{%- endif %}
{%- if ollama_mode == "docker" %}

  ollama:
    ports:
      # Host port auto-selected by `make serve` (OLLAMA_HOST_PORT). The
      # container still listens on 11434 for in-network clients.
      - "${OLLAMA_HOST_PORT:-11434}:11434"
{%- endif %}
{%- if include_ingress %}

  traefik:
{%- if ingress_tls %}
    volumes:
      - ./traefik/traefik.dev.yml:/etc/traefik/traefik.yml:ro
{%- endif %}
    ports:
      # Host ports auto-selected by `make serve` (INGRESS_HTTP_PORT /
      # INGRESS_DASHBOARD_PORT); fall back to the standard ports for a
      # raw `docker compose up`.
      - "${INGRESS_HTTP_PORT:-80}:80"
      - "${INGRESS_DASHBOARD_PORT:-8080}:8080"  # Dashboard
{%- endif %}

  test_runner:
    volumes:
      - .:/code
{%- if include_htmx %}

  tailwind:
    image: node:22-alpine
    working_dir: /code
    volumes:
      - .:/code
    environment:
      CHOKIDAR_USEPOLLING: "true"
      CHOKIDAR_INTERVAL: "1000"
    entrypoint: sh
    command:
      - -c
      - npm install --no-audit --no-fund --silent && exec npx tailwindcss -i /code/app/components/web_frontend/static/input.css -o /code/app/components/web_frontend/static/dist/app.css --watch=always
    profiles:
      - dev

  build-static-watcher:
    image: ${AEGIS_STACK_TAG:-aegis-stack:latest}
    env_file:
      - ${AEGIS_STACK_ENV_FILE:-.env}
    working_dir: /code
    volumes:
      - .:/code
    command:
      - build-watch
    profiles:
      - dev
{%- endif %}
{%- if include_finance and finance_plaid %}

  plaid-tunnel:
    image: cloudflare/cloudflared:latest
    command: tunnel --no-autoupdate --metrics 0.0.0.0:20241 --url http://webserver:${PORT:-8000}
    restart: unless-stopped
    profiles:
      - dev
{%- endif %}
