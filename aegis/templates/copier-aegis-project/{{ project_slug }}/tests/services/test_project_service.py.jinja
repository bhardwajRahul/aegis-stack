@pytest.mark.asyncio
async def test_delete_removes_project(async_db_session: AsyncSession) -> None:
    user, org_id = await _seed_user(async_db_session)
    service = ProjectService(async_db_session)
    await service.create(
        owner_user_id=user.id,
        organization_id=org_id,  # type: ignore[arg-type]
        slug="p", name="P",  # type: ignore[arg-type]
    )

    deleted = await service.delete("p", user.id)  # type: ignore[arg-type]

    assert deleted is True
    assert await service.get_by_slug_for_user("p", user.id) is None  # type: ignore[arg-type]


@pytest.mark.asyncio
async def test_delete_returns_false_for_non_owner(
    async_db_session: AsyncSession,
) -> None:
    owner, owner_org_id = await _seed_user(async_db_session, "owner@x.com")
    intruder, intruder_org_id = await _seed_user(async_db_session, "intruder@x.com")
    service = ProjectService(async_db_session)
    await service.create(
        owner_user_id=owner.id,
        organization_id=owner_org_id,  # type: ignore[arg-type]
        slug="p", name="P",  # type: ignore[arg-type]
    )

    deleted = await service.delete("p", intruder.id)  # type: ignore[arg-type]

    assert deleted is False
    # Still there for the real owner.
    assert await service.get_by_slug_for_user("p", owner.id) is not None  # type: ignore[arg-type]
