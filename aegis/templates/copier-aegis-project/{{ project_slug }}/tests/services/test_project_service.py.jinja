"""Tests for ProjectService — CRUD + transparent credential encryption.

The service is the only layer that touches encrypt/decrypt. Tests
verify both halves of the contract: the DB row holds ciphertext, and
the in-memory object handed back to callers holds plaintext.
"""

from __future__ import annotations

import pytest
from app.core.encryption import decrypt_secret
from app.models.user import User
from app.services.insights.models import Project
from app.services.insights.project_service import ProjectService
from sqlalchemy import text
from sqlmodel.ext.asyncio.session import AsyncSession


async def _seed_user(
    session: AsyncSession, email: str = "u@example.com"
) -> tuple[User, int]:
    """Create a test user plus an org + owner membership.

    Returns ``(user, org_id)`` — the template's ``User`` model doesn't
    ship a ``default_organization_id`` field (that's downstream-app
    policy à la Pulse), so the helper hands the org id back as a
    second tuple element instead. Tests pass it as
    ``organization_id=org_id`` when building Project rows.
    """
    from tests._test_org import ensure_org_for_user

    user = User(email=email, full_name="Test", hashed_password="x")
    session.add(user)
    await session.flush()
    org_id = await ensure_org_for_user(session, user)
    return user, org_id


async def _raw_project_row(session: AsyncSession, slug: str) -> dict:
    """Bypass the service to read what's actually persisted in the row."""
    result = await session.exec(
        text("SELECT github_token, plausible_api_key FROM project WHERE slug = :slug"),
        params={"slug": slug},
    )
    row = result.first()
    assert row is not None
    return {"github_token": row[0], "plausible_api_key": row[1]}


# ---------------------------------------------------------------------------
# create
# ---------------------------------------------------------------------------


@pytest.mark.asyncio
async def test_create_persists_credentials_encrypted_in_db(
    async_db_session: AsyncSession,
) -> None:
    user, org_id = await _seed_user(async_db_session)
    service = ProjectService(async_db_session)

    await service.create(
        owner_user_id=user.id,  # type: ignore[arg-type]
        organization_id=org_id,  # type: ignore[arg-type]
        slug="my-project",
        name="My Project",
        github_token="ghp_abc123",
        plausible_api_key="pk_xyz789",
    )

    row = await _raw_project_row(async_db_session, "my-project")
    assert row["github_token"] != "ghp_abc123"
    assert row["plausible_api_key"] != "pk_xyz789"
    # And they're recoverable through the encryption layer.
    assert decrypt_secret(row["github_token"]) == "ghp_abc123"
    assert decrypt_secret(row["plausible_api_key"]) == "pk_xyz789"


@pytest.mark.asyncio
async def test_create_returns_plaintext_to_caller(
    async_db_session: AsyncSession,
) -> None:
    user, org_id = await _seed_user(async_db_session)
    service = ProjectService(async_db_session)

