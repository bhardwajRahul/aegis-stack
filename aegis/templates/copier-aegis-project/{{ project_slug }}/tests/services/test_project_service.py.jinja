# list_for_user
# ---------------------------------------------------------------------------


@pytest.mark.asyncio
async def test_list_for_user_filters_by_owner(
    async_db_session: AsyncSession,
) -> None:
    a, a_org_id = await _seed_user(async_db_session, "a@x.com")
    b, b_org_id = await _seed_user(async_db_session, "b@x.com")
    service = ProjectService(async_db_session)
    await service.create(owner_user_id=a.id,
        organization_id=a_org_id,  # type: ignore[arg-type]
        slug="a1", name="a1")  # type: ignore[arg-type]
    await service.create(owner_user_id=a.id,
        organization_id=a_org_id,  # type: ignore[arg-type]
        slug="a2", name="a2")  # type: ignore[arg-type]
    await service.create(owner_user_id=b.id,
        organization_id=b_org_id,  # type: ignore[arg-type]
        slug="b1", name="b1")  # type: ignore[arg-type]

    a_projects = await service.list_for_user(a.id)  # type: ignore[arg-type]

    slugs = {p.slug for p in a_projects}
    assert slugs == {"a1", "a2"}


