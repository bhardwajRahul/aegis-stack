@pytest.mark.asyncio
async def test_update_re_encrypts_changed_credentials(
    async_db_session: AsyncSession,
) -> None:
    user, org_id = await _seed_user(async_db_session)
    service = ProjectService(async_db_session)
    await service.create(
        owner_user_id=user.id,  # type: ignore[arg-type]
        organization_id=org_id,  # type: ignore[arg-type]
        slug="p", name="P", github_token="ghp_old",
    )

    updated = await service.update(
        "p", user.id, github_token="ghp_new",  # type: ignore[arg-type]
    )

    assert updated is not None
    assert updated.github_token == "ghp_new"
    row = await _raw_project_row(async_db_session, "p")
    assert decrypt_secret(row["github_token"]) == "ghp_new"


@pytest.mark.asyncio
async def test_update_ignores_unknown_fields(
    async_db_session: AsyncSession,
) -> None:
    user, org_id = await _seed_user(async_db_session)
    service = ProjectService(async_db_session)
    project = await service.create(
        owner_user_id=user.id,
        organization_id=org_id,  # type: ignore[arg-type]
        slug="p", name="P",  # type: ignore[arg-type]
    )
    original_owner = project.owner_user_id

    updated = await service.update(
        "p",
        user.id,  # type: ignore[arg-type]
        bogus_field="ignored",  # not in allow-list
        id=999,  # not in allow-list
        name="Updated",
    )

    assert updated is not None
    assert updated.name == "Updated"
    # Owner unchanged (no path to mutate it via update())
    assert updated.owner_user_id == original_owner
    assert updated.slug == "p"


