class TestRefreshServiceLazySweep:
    """Builds without the scheduler component clean up expired rows
    opportunistically from ``rotate``. The first eligible rotation
    primes the sweep; subsequent rotations within the interval are
    skipped (the table delete is bounded to ~1/hour)."""

    @pytest.mark.asyncio
    async def test_rotate_sweeps_expired_rows(
        self, async_db_session: AsyncSession
    ):
        from app.services.auth.refresh_service import (
            REFRESH_TOKEN_RETENTION_DAYS,
            RefreshService,
        )

        # Force the sweep gate open for this test — the class-level
        # timestamp survives across tests in the same process.
        RefreshService._last_sweep_at = None

        user_id = await _make_user(async_db_session, "lazy-sweep@example.com")
        service = RefreshService(async_db_session)

        # Plant an expired row beyond the retention window.
        old = RefreshToken(
            token="expired-stub-token",
            user_id=user_id,
            family_id="expired-family",
            expires_at=_now() - timedelta(days=REFRESH_TOKEN_RETENTION_DAYS + 1),
            created_at=_now() - timedelta(days=REFRESH_TOKEN_RETENTION_DAYS + 2),
        )
        async_db_session.add(old)
        await async_db_session.commit()

        # A live token whose rotation will trigger the sweep.
        live = await service.mint(user_id, source="password")
        rotated = await service.rotate(live)
        assert rotated is not None

        gone = await async_db_session.get(RefreshToken, "expired-stub-token")
        assert gone is None
