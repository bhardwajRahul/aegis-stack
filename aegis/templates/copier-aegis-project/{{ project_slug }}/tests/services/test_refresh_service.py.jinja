"""Unit tests for ``RefreshService``: mint, rotate, revoke, reuse-detect."""

from datetime import UTC, datetime, timedelta

import pytest
from app.models.refresh_token import RefreshToken
from app.models.user import UserCreate
from app.services.auth.refresh_service import RefreshService
from app.services.auth.user_service import UserService
from sqlmodel.ext.asyncio.session import AsyncSession


def _now() -> datetime:
    return datetime.now(UTC).replace(tzinfo=None)


async def _make_user(db: AsyncSession, email: str) -> int:
    user = await UserService(db).create_user(
        UserCreate(email=email, full_name="Test", password="password123")
    )
    return user.id  # type: ignore[return-value]


class TestRefreshService:
    @pytest.mark.asyncio
    async def test_mint_returns_url_safe_token(self, async_db_session: AsyncSession):
        user_id = await _make_user(async_db_session, "mint@example.com")
        token = await RefreshService(async_db_session).mint(user_id)
        assert isinstance(token, str)
        assert len(token) >= 32

    @pytest.mark.asyncio
    async def test_validate_returns_user_id_for_live_token(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "validate@example.com")
        service = RefreshService(async_db_session)
        token = await service.mint(user_id)
        assert await service.validate(token) == user_id

    @pytest.mark.asyncio
    async def test_validate_returns_none_for_missing_token(
        self, async_db_session: AsyncSession
    ):
        service = RefreshService(async_db_session)
        assert await service.validate("nonexistent-token") is None

    @pytest.mark.asyncio
    async def test_rotate_revokes_inbound_and_mints_new(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "rotate@example.com")
        service = RefreshService(async_db_session)
        original = await service.mint(user_id)

        result = await service.rotate(original)
        assert result is not None
        new_token, returned_uid = result
        assert returned_uid == user_id
        assert new_token != original

        # Inbound is revoked, new is live, both share family.
        original_row = await async_db_session.get(RefreshToken, original)
        new_row = await async_db_session.get(RefreshToken, new_token)
        assert original_row is not None and original_row.revoked_at is not None
        assert new_row is not None and new_row.revoked_at is None
        assert new_row.family_id == original_row.family_id

    @pytest.mark.asyncio
    async def test_rotate_returns_none_for_missing_token(
        self, async_db_session: AsyncSession
    ):
        assert await RefreshService(async_db_session).rotate("nope") is None

    @pytest.mark.asyncio
    async def test_rotate_returns_none_for_expired_token(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "expired@example.com")
        service = RefreshService(async_db_session)
        token = await service.mint(user_id)
        # Backdate expiration in place.
        row = await async_db_session.get(RefreshToken, token)
        assert row is not None
        row.expires_at = _now() - timedelta(seconds=1)
        async_db_session.add(row)
        await async_db_session.commit()

        assert await service.rotate(token) is None

    @pytest.mark.asyncio
    async def test_reuse_of_revoked_token_nukes_family(
        self, async_db_session: AsyncSession
    ):
        """Replay path: rotate a token successfully, then rotate the original
        again — service must revoke every live row in the family.
        """
        user_id = await _make_user(async_db_session, "replay@example.com")
        service = RefreshService(async_db_session)
        original = await service.mint(user_id)

        # First rotation succeeds.
        first = await service.rotate(original)
        assert first is not None
        new_token, _ = first

        # Attacker replays the original (already revoked).
        replay_result = await service.rotate(original)
        assert replay_result is None

        # The successor token is now also revoked.
        successor_row = await async_db_session.get(RefreshToken, new_token)
        assert successor_row is not None
        assert successor_row.revoked_at is not None

    @pytest.mark.asyncio
    async def test_revoke_marks_row_revoked(self, async_db_session: AsyncSession):
        user_id = await _make_user(async_db_session, "revoke@example.com")
        service = RefreshService(async_db_session)
        token = await service.mint(user_id)

        await service.revoke(token)

        row = await async_db_session.get(RefreshToken, token)
        assert row is not None and row.revoked_at is not None

    @pytest.mark.asyncio
    async def test_revoke_is_idempotent_for_missing_token(
        self, async_db_session: AsyncSession
    ):
        # Should not raise — logout with a stale cookie must succeed.
        await RefreshService(async_db_session).revoke("missing")

    @pytest.mark.asyncio
    async def test_list_active_for_user_returns_only_live_rows(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "active@example.com")
        service = RefreshService(async_db_session)
        live = await service.mint(user_id)
        await service.mint(user_id)
        await service.revoke(live)

        active = await service.list_active_for_user(user_id)
        assert all(row.revoked_at is None for row in active)
        assert len(active) == 1


class TestRefreshServiceSessionMetadata:
    """Coverage for the active-sessions extensions (#633)."""

    @pytest.mark.asyncio
    async def test_mint_persists_source_user_agent_ip(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "meta@example.com")
        service = RefreshService(async_db_session)
        token = await service.mint(
            user_id,
            source="password",
            user_agent="pytest/1.0",
            ip="127.0.0.1",
        )
        row = await async_db_session.get(RefreshToken, token)
        assert row is not None
        assert row.source == "password"
        assert row.user_agent == "pytest/1.0"
        assert row.ip == "127.0.0.1"

    @pytest.mark.asyncio
    async def test_rotate_bumps_last_used_and_carries_source_forward(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "rotate-meta@example.com")
        service = RefreshService(async_db_session)
        original = await service.mint(
            user_id,
            source="oauth:github",
            user_agent="ua-original",
            ip="1.1.1.1",
        )
        rotated = await service.rotate(
            original, user_agent="ua-rotated", ip="2.2.2.2"
        )
        assert rotated is not None
        new_token, _ = rotated

        new_row = await async_db_session.get(RefreshToken, new_token)
        assert new_row is not None
        # source is sticky across rotation
        assert new_row.source == "oauth:github"
        # UA/IP refresh on rotation
        assert new_row.user_agent == "ua-rotated"
        assert new_row.ip == "2.2.2.2"
        # last_used_at is set on the new row at rotation time
        assert new_row.last_used_at is not None

    @pytest.mark.asyncio
    async def test_list_sessions_returns_one_per_family(
        self, async_db_session: AsyncSession
    ):
        """After one mint + one rotation, ``list_sessions`` should
        collapse to a single session entry (most recent live row per
        family)."""
        user_id = await _make_user(async_db_session, "list-sessions@example.com")
        service = RefreshService(async_db_session)
        original = await service.mint(user_id, source="password")
        await service.rotate(original)

        sessions = await service.list_sessions(user_id)
        assert len(sessions) == 1

    @pytest.mark.asyncio
    async def test_list_sessions_excludes_revoked_families(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "revoked-list@example.com")
        service = RefreshService(async_db_session)
        t1 = await service.mint(user_id, source="password")
        await service.mint(user_id, source="oauth:github")
        await service.revoke(t1)

        sessions = await service.list_sessions(user_id)
        assert len(sessions) == 1
        assert sessions[0].source == "oauth:github"

    @pytest.mark.asyncio
    async def test_revoke_session_kills_whole_family(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "revoke-fam@example.com")
        service = RefreshService(async_db_session)
        original = await service.mint(user_id, source="password")
        rotated = await service.rotate(original)
        assert rotated is not None
        new_token, _ = rotated

        new_row = await async_db_session.get(RefreshToken, new_token)
        assert new_row is not None
        ok = await service.revoke_session(new_row.family_id, user_id)
        assert ok is True

        sessions = await service.list_sessions(user_id)
        assert sessions == []

    @pytest.mark.asyncio
    async def test_revoke_session_returns_false_for_other_user(
        self, async_db_session: AsyncSession
    ):
        mine = await _make_user(async_db_session, "me@example.com")
        theirs = await _make_user(async_db_session, "you@example.com")
        service = RefreshService(async_db_session)
        their_token = await service.mint(theirs, source="password")
        their_row = await async_db_session.get(RefreshToken, their_token)
        assert their_row is not None

        ok = await service.revoke_session(their_row.family_id, mine)
        assert ok is False

        # Theirs is still live.
        sessions = await service.list_sessions(theirs)
        assert len(sessions) == 1

    @pytest.mark.asyncio
    async def test_revoke_other_sessions_keeps_one(
        self, async_db_session: AsyncSession
    ):
        user_id = await _make_user(async_db_session, "logout-others@example.com")
        service = RefreshService(async_db_session)
        keep_token = await service.mint(user_id, source="password")
        keep_row = await async_db_session.get(RefreshToken, keep_token)
        assert keep_row is not None
        await service.mint(user_id, source="oauth:github")
        await service.mint(user_id, source="oauth:google")

        revoked = await service.revoke_other_sessions(keep_row.family_id, user_id)
        assert revoked == 2

        sessions = await service.list_sessions(user_id)
        assert len(sessions) == 1
        assert sessions[0].family_id == keep_row.family_id


