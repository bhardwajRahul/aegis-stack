"""
Integration tests for organization services.

Tests org CRUD, membership management, and role-based access controls.

Test-data setup uses the composable factories declared in
``tests/conftest.py``. Inline ``OrgCreate(...)`` / ``UserCreate(...)``
is reserved for tests whose explicit name / slug / email value is the
invariant being tested (slug uniqueness, soft-delete re-registration,
invite email matching).
"""
{% if include_auth_org %}

import pytest
from app.models.org import (
    OrgCreate,
    Organization,
    ORG_ROLE_ADMIN,
    ORG_ROLE_MEMBER,
    ORG_ROLE_OWNER,
)
from app.services.auth.invite_service import InviteService
from app.services.auth.membership_service import MembershipService
from app.services.auth.org_service import OrgService, RestoreConflict
from sqlmodel import select
from sqlmodel.ext.asyncio.session import AsyncSession


class TestOrgServiceIntegration:
    """Test organization service CRUD operations."""

    @pytest.mark.asyncio
    async def test_create_org(self, async_db_session: AsyncSession) -> None:
        """Test creating an organization.

        Inline: the test asserts on the exact name / slug values that
        come back from ``create_org``, so the inputs need to be visible.
        """
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(OrgCreate(name="Test Org", slug="test-org"))

        assert org.id is not None
        assert org.name == "Test Org"
        assert org.slug == "test-org"
        assert org.is_active is True
        assert org.created_at is not None

    @pytest.mark.asyncio
    async def test_get_org_by_id(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """Test retrieving an organization by ID."""
        org_service = OrgService(async_db_session)
        org = await org_factory()

        retrieved = await org_service.get_org_by_id(org.id)
        assert retrieved is not None
        assert retrieved.id == org.id

    @pytest.mark.asyncio
    async def test_get_org_by_slug(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """Test retrieving an organization by slug.

        Inline-ish: we lookup by the factory's returned slug, so we
        don't have to pin a literal — the test point is the
        round-trip, not the slug value.
        """
        org_service = OrgService(async_db_session)
        org = await org_factory()

        retrieved = await org_service.get_org_by_slug(org.slug)
        assert retrieved is not None
        assert retrieved.slug == org.slug

    @pytest.mark.asyncio
    async def test_get_nonexistent_org(self, async_db_session: AsyncSession) -> None:
        """Test retrieving a nonexistent organization returns None."""
        org_service = OrgService(async_db_session)
        assert await org_service.get_org_by_id(999) is None
        assert await org_service.get_org_by_slug("nonexistent") is None

    @pytest.mark.asyncio
    async def test_update_org(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """Test updating an organization."""
        org_service = OrgService(async_db_session)
        org = await org_factory()

        updated = await org_service.update_org(org.id, name="Updated")
        assert updated is not None
        assert updated.name == "Updated"
