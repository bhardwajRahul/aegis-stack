    @pytest.mark.asyncio
    async def test_bulk_add_members(self, async_db_session: AsyncSession) -> None:
        """Test bulk-adding multiple users to an organization."""
        users = [
            await self._create_user(async_db_session, f"bulk{i}@test.com")
            for i in range(5)
        ]
        org = await self._create_org(async_db_session, "bulk-test")

        membership_service = MembershipService(async_db_session)
        user_ids = [u.id for u in users]
        added = await membership_service.bulk_add_members(org.id, user_ids)

        assert len(added) == 5
        members = await membership_service.list_org_members(org.id)
        assert len(members) == 5
        assert all(m.role == ORG_ROLE_MEMBER for m in members)

    @pytest.mark.asyncio
    async def test_bulk_add_members_with_role(self, async_db_session: AsyncSession) -> None:
        """Test bulk-adding members with a specific role."""
        users = [
            await self._create_user(async_db_session, f"bulkrole{i}@test.com")
            for i in range(3)
        ]
        org = await self._create_org(async_db_session, "bulk-role-test")

        membership_service = MembershipService(async_db_session)
        user_ids = [u.id for u in users]
        added = await membership_service.bulk_add_members(
            org.id, user_ids, role=ORG_ROLE_ADMIN
        )

        assert len(added) == 3
        assert all(m.role == ORG_ROLE_ADMIN for m in added)

    @pytest.mark.asyncio
    async def test_bulk_add_members_skips_existing(self, async_db_session: AsyncSession) -> None:
        """Test that bulk add skips users who are already members."""
        users = [
            await self._create_user(async_db_session, f"bulkskip{i}@test.com")
            for i in range(4)
        ]
        org = await self._create_org(async_db_session, "bulk-skip-test")

        membership_service = MembershipService(async_db_session)

        # Add first two individually
        await membership_service.add_member(org.id, users[0].id, role=ORG_ROLE_OWNER)
        await membership_service.add_member(org.id, users[1].id)

        # Bulk add all four — should only add the last two
        all_ids = [u.id for u in users]
        added = await membership_service.bulk_add_members(org.id, all_ids)

        assert len(added) == 2
        added_ids = {m.user_id for m in added}
        assert users[2].id in added_ids
        assert users[3].id in added_ids

        # Verify existing members kept their original roles
        owner = await membership_service.get_member(org.id, users[0].id)
        assert owner is not None
        assert owner.role == ORG_ROLE_OWNER

    @pytest.mark.asyncio
    async def test_bulk_add_members_empty_list(self, async_db_session: AsyncSession) -> None:
        """Test bulk add with empty list returns empty."""
        org = await self._create_org(async_db_session, "bulk-empty-test")

        membership_service = MembershipService(async_db_session)
        added = await membership_service.bulk_add_members(org.id, [])

        assert added == []

    @pytest.mark.asyncio
    async def test_bulk_add_members_invalid_role(self, async_db_session: AsyncSession) -> None:
        """Test bulk add with invalid role raises ValueError."""
        org = await self._create_org(async_db_session, "bulk-invalid-test")

        membership_service = MembershipService(async_db_session)
        with pytest.raises(ValueError, match="Invalid org role"):
            await membership_service.bulk_add_members(org.id, [1], role="superadmin")

    @pytest.mark.asyncio
    async def test_bulk_add_members_all_existing(self, async_db_session: AsyncSession) -> None:
        """Test bulk add when all users are already members returns empty."""
        users = [
            await self._create_user(async_db_session, f"bulkall{i}@test.com")
            for i in range(3)
        ]
        org = await self._create_org(async_db_session, "bulk-all-existing")

        membership_service = MembershipService(async_db_session)
        for u in users:
            await membership_service.add_member(org.id, u.id)

        # Bulk add the same users — should add none
        all_ids = [u.id for u in users]
        added = await membership_service.bulk_add_members(org.id, all_ids)

        assert added == []


class TestInviteServiceIntegration:
    """Test invite service operations (AUTH-013)."""

    async def _create_user(self, db: AsyncSession, email: str) -> "User":
        from app.models.user import User
        user_service = UserService(db)
        return await user_service.create_user(
            UserCreate(email=email, full_name="Test", password="password123")
        )

    async def _create_org(self, db: AsyncSession, slug: str) -> Organization:
        org_service = OrgService(db)
        return await org_service.create_org(OrgCreate(name=slug.title(), slug=slug))

    @pytest.mark.asyncio
    async def test_invite_new_user(self, async_db_session: AsyncSession) -> None:
        """Inviting an email that doesn't exist creates a pending invite."""
        owner = await self._create_user(async_db_session, "inv-owner@test.com")
        org = await self._create_org(async_db_session, "inv-test")

        invite_service = InviteService(async_db_session)
        invite = await invite_service.create_invite(
            org.id, "newuser@test.com", "member", owner.id
        )

        assert invite.status == "pending"
        assert invite.email == "newuser@test.com"
        assert invite.organization_id == org.id

    @pytest.mark.asyncio
    async def test_invite_existing_user_auto_adds(self, async_db_session: AsyncSession) -> None:
        """Inviting an existing user immediately adds them to the org."""
        owner = await self._create_user(async_db_session, "inv-owner2@test.com")
        target = await self._create_user(async_db_session, "existing@test.com")
        org = await self._create_org(async_db_session, "inv-existing")

        invite_service = InviteService(async_db_session)
        invite = await invite_service.create_invite(
            org.id, "existing@test.com", "admin", owner.id
        )

        assert invite.status == "accepted"

        membership_service = MembershipService(async_db_session)
        member = await membership_service.get_member(org.id, target.id)
        assert member is not None
        assert member.role == "admin"

    @pytest.mark.asyncio
    async def test_pending_invite_accepted_on_registration(
        self, async_db_session: AsyncSession
    ) -> None:
        """Pending invite is accepted when the user registers."""
        owner = await self._create_user(async_db_session, "inv-owner3@test.com")
        org = await self._create_org(async_db_session, "inv-register")

        invite_service = InviteService(async_db_session)
        await invite_service.create_invite(
            org.id, "future@test.com", "member", owner.id
        )

        new_user = await self._create_user(async_db_session, "future@test.com")
        count = await invite_service.accept_pending_invites("future@test.com", new_user.id)

        assert count == 1

        membership_service = MembershipService(async_db_session)
        member = await membership_service.get_member(org.id, new_user.id)
        assert member is not None
        assert member.role == "member"

    @pytest.mark.asyncio
    async def test_duplicate_invite_raises(self, async_db_session: AsyncSession) -> None:
        """Cannot create duplicate pending invite for same email + org."""
        owner = await self._create_user(async_db_session, "inv-owner4@test.com")
        org = await self._create_org(async_db_session, "inv-dup")

        invite_service = InviteService(async_db_session)
        await invite_service.create_invite(org.id, "dup@test.com", "member", owner.id)

        with pytest.raises(ValueError, match="Pending invite already exists"):
            await invite_service.create_invite(org.id, "dup@test.com", "member", owner.id)

    @pytest.mark.asyncio
    async def test_list_pending_invites(self, async_db_session: AsyncSession) -> None:
        """List only pending invites for an org."""
        owner = await self._create_user(async_db_session, "inv-owner5@test.com")
        org = await self._create_org(async_db_session, "inv-list")

        invite_service = InviteService(async_db_session)
        await invite_service.create_invite(org.id, "pending1@test.com", "member", owner.id)
        await invite_service.create_invite(org.id, "pending2@test.com", "admin", owner.id)

        pending = await invite_service.list_pending_invites(org.id)
        assert len(pending) == 2
        emails = {inv.email for inv in pending}
        assert "pending1@test.com" in emails
        assert "pending2@test.com" in emails

