    @pytest.mark.asyncio
    async def test_add_member(self, async_db_session: AsyncSession) -> None:
        """Test adding a member to an organization."""
        user = await self._create_user(async_db_session, "member1@test.com")
        org = await self._create_org(async_db_session, "member-test")

        membership_service = MembershipService(async_db_session)
