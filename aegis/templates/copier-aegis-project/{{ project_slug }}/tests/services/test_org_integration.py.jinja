    @pytest.mark.asyncio
    async def test_delete_org(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """Test deleting an organization."""
        org_service = OrgService(async_db_session)
        org = await org_factory()

        success = await org_service.delete_org(org.id)
        assert success is True
        assert await org_service.get_org_by_id(org.id) is None

    @pytest.mark.asyncio
    async def test_delete_org_with_members(
        self,
        async_db_session: AsyncSession,
        user_factory,
        org_factory,
    ) -> None:
        """Test deleting an org that has members cascades to remove members too."""
        org = await org_factory()
        users = [await user_factory() for _ in range(3)]

        membership_service = MembershipService(async_db_session)
        for u in users:
            await membership_service.add_member(org.id, u.id)

        members = await membership_service.list_org_members(org.id)
        assert len(members) == 3

        org_service = OrgService(async_db_session)
        success = await org_service.delete_org(org.id)
        assert success is True
        assert await org_service.get_org_by_id(org.id) is None

        members = await membership_service.list_org_members(org.id)
        assert len(members) == 0

    @pytest.mark.asyncio
    async def test_delete_nonexistent_org(self, async_db_session: AsyncSession) -> None:
        """Test deleting a nonexistent organization returns False."""
        org_service = OrgService(async_db_session)
        assert await org_service.delete_org(999) is False

    @pytest.mark.asyncio
    async def test_soft_delete_org_keeps_row(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """Soft-delete sets ``deleted_at`` and hides the org from lookups."""
        org_service = OrgService(async_db_session)
        org = await org_factory()
        slug = org.slug

        assert await org_service.delete_org(org.id) is True

        # Filtered queries can't see it.
        assert await org_service.get_org_by_id(org.id) is None
        assert await org_service.get_org_by_slug(slug) is None
        assert not any(o.id == org.id for o in await org_service.list_orgs())

        # Row still present with deleted_at populated.
        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == org.id)
        )
        row = raw.first()
        assert row is not None
        assert row.deleted_at is not None

    @pytest.mark.asyncio
    async def test_hard_delete_org(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """``hard_delete_org`` removes the org row entirely."""
        org_service = OrgService(async_db_session)
        org = await org_factory()

        assert await org_service.hard_delete_org(org.id) is True

        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == org.id)
        )
        assert raw.first() is None

    @pytest.mark.asyncio
    async def test_reregister_slug_after_soft_delete(
        self, async_db_session: AsyncSession
    ) -> None:
        """Same slug can be reused after the original org is soft-deleted.

        Inline: literal slug reuse is the test invariant — the partial
        unique index ``ix_organization_slug`` exists for this exact case.
        """
        org_service = OrgService(async_db_session)
        first = await org_service.create_org(
            OrgCreate(name="Acme", slug="acme")
        )
        await org_service.delete_org(first.id)

        second = await org_service.create_org(
            OrgCreate(name="Acme Returns", slug="acme")
        )
        assert second.id != first.id

        live = await org_service.get_org_by_slug("acme")
        assert live is not None
        assert live.id == second.id

    @pytest.mark.asyncio
    async def test_restore_org(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """``restore_org`` clears ``deleted_at`` on a soft-deleted org."""
        org_service = OrgService(async_db_session)
        org = await org_factory()
        await org_service.delete_org(org.id)
        assert await org_service.get_org_by_id(org.id) is None

        restored = await org_service.restore_org(org.id)
        assert restored is not None
        assert restored.id == org.id
        assert restored.deleted_at is None
        assert await org_service.get_org_by_id(org.id) is not None

    @pytest.mark.asyncio
    async def test_restore_org_noop_on_live(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """``restore_org`` on a non-deleted org returns ``None``."""
        org_service = OrgService(async_db_session)
        org = await org_factory()
        assert await org_service.restore_org(org.id) is None

    @pytest.mark.asyncio
    async def test_restore_org_conflict_when_slug_reused(
        self, async_db_session: AsyncSession
    ) -> None:
        """Restore must refuse if the slug was reclaimed by re-creation.

        Inline: literal slug collision is the test invariant.
        """
        org_service = OrgService(async_db_session)
        original = await org_service.create_org(
            OrgCreate(name="Acme", slug="acme")
        )
        await org_service.delete_org(original.id)
        replacement = await org_service.create_org(
            OrgCreate(name="Acme Returns", slug="acme")
        )
        assert replacement.id != original.id

        with pytest.raises(RestoreConflict):
            await org_service.restore_org(original.id)

        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == original.id)
        )
        row = raw.first()
        assert row is not None
        assert row.deleted_at is not None

    @pytest.mark.asyncio
    async def test_hard_delete_org_after_soft_delete(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """``hard_delete_org`` purges an already-soft-deleted org."""
        org_service = OrgService(async_db_session)
        org = await org_factory()
        await org_service.delete_org(org.id)
        assert await org_service.hard_delete_org(org.id) is True

        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == org.id)
        )
        assert raw.first() is None

    @pytest.mark.asyncio
    async def test_list_orgs(
        self, async_db_session: AsyncSession, org_factory
    ) -> None:
        """Test listing organizations."""
        org_service = OrgService(async_db_session)
        a = await org_factory()
        b = await org_factory()

        orgs = await org_service.list_orgs()
        assert len(orgs) >= 2
        slugs = {o.slug for o in orgs}
        assert a.slug in slugs
        assert b.slug in slugs


