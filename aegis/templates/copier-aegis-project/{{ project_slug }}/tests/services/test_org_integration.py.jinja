"""
Integration tests for organization services.

Tests org CRUD, membership management, and role-based access controls.
"""
{% if include_auth_org %}

import pytest
from app.models.org import (
    OrgCreate,
    Organization,
    OrganizationMember,
    ORG_ROLE_ADMIN,
    ORG_ROLE_MEMBER,
    ORG_ROLE_OWNER,
)
from app.models.user import User, UserCreate
from app.services.auth.invite_service import InviteService
from app.services.auth.membership_service import MembershipService
from app.services.auth.org_service import OrgService, RestoreConflict
from app.services.auth.user_service import UserService
from sqlmodel import select
from sqlmodel.ext.asyncio.session import AsyncSession


class TestOrgServiceIntegration:
    """Test organization service CRUD operations."""

    @pytest.mark.asyncio
    async def test_create_org(self, async_db_session: AsyncSession) -> None:
        """Test creating an organization."""
        org_service = OrgService(async_db_session)
        org_data = OrgCreate(name="Test Org", slug="test-org")
        org = await org_service.create_org(org_data)

        assert org.id is not None
        assert org.name == "Test Org"
        assert org.slug == "test-org"
        assert org.is_active is True
        assert org.created_at is not None

    @pytest.mark.asyncio
    async def test_get_org_by_id(self, async_db_session: AsyncSession) -> None:
        """Test retrieving an organization by ID."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(OrgCreate(name="By ID", slug="by-id"))

        retrieved = await org_service.get_org_by_id(org.id)
        assert retrieved is not None
        assert retrieved.id == org.id
        assert retrieved.name == "By ID"

    @pytest.mark.asyncio
    async def test_get_org_by_slug(self, async_db_session: AsyncSession) -> None:
        """Test retrieving an organization by slug."""
        org_service = OrgService(async_db_session)
        await org_service.create_org(OrgCreate(name="By Slug", slug="by-slug"))

        retrieved = await org_service.get_org_by_slug("by-slug")
        assert retrieved is not None
        assert retrieved.slug == "by-slug"

    @pytest.mark.asyncio
    async def test_get_nonexistent_org(self, async_db_session: AsyncSession) -> None:
        """Test retrieving a nonexistent organization returns None."""
        org_service = OrgService(async_db_session)
        assert await org_service.get_org_by_id(999) is None
        assert await org_service.get_org_by_slug("nonexistent") is None

    @pytest.mark.asyncio
    async def test_update_org(self, async_db_session: AsyncSession) -> None:
        """Test updating an organization."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(OrgCreate(name="Original", slug="original"))

        updated = await org_service.update_org(org.id, name="Updated")
        assert updated is not None
        assert updated.name == "Updated"
        assert updated.updated_at is not None

    @pytest.mark.asyncio
    async def test_delete_org(self, async_db_session: AsyncSession) -> None:
        """Test deleting an organization."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(OrgCreate(name="Delete Me", slug="delete-me"))

        success = await org_service.delete_org(org.id)
        assert success is True
        assert await org_service.get_org_by_id(org.id) is None

    @pytest.mark.asyncio
    async def test_delete_org_with_members(self, async_db_session: AsyncSession) -> None:
        """Test deleting an org that has members cascades to remove members too."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(
            OrgCreate(name="Has Members", slug="has-members")
        )

        # Add some members
        user_service = UserService(async_db_session)
        users = [
            await user_service.create_user(
                UserCreate(
                    email=f"deltest{i}@test.com",
                    full_name=f"Del Test {i}",
                    password="password123",
                )
            )
            for i in range(3)
        ]
        membership_service = MembershipService(async_db_session)
        for u in users:
            await membership_service.add_member(org.id, u.id)

        # Verify members exist
        members = await membership_service.list_org_members(org.id)
        assert len(members) == 3

        # Delete org — should succeed and remove members
        success = await org_service.delete_org(org.id)
        assert success is True
        assert await org_service.get_org_by_id(org.id) is None

        # Members should be gone too
        members = await membership_service.list_org_members(org.id)
        assert len(members) == 0

    @pytest.mark.asyncio
    async def test_delete_nonexistent_org(self, async_db_session: AsyncSession) -> None:
        """Test deleting a nonexistent organization returns False."""
        org_service = OrgService(async_db_session)
        assert await org_service.delete_org(999) is False

    @pytest.mark.asyncio
    async def test_soft_delete_org_keeps_row(
        self, async_db_session: AsyncSession
    ) -> None:
        """Soft-delete sets ``deleted_at`` and hides the org from lookups."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(
            OrgCreate(name="Soft Org", slug="soft-org")
        )

        assert await org_service.delete_org(org.id) is True

        # Filtered queries can't see it.
        assert await org_service.get_org_by_id(org.id) is None
        assert await org_service.get_org_by_slug("soft-org") is None
        assert not any(o.id == org.id for o in await org_service.list_orgs())

        # Row still present with deleted_at populated.
        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == org.id)
        )
        row = raw.first()
        assert row is not None
        assert row.deleted_at is not None

    @pytest.mark.asyncio
    async def test_hard_delete_org(self, async_db_session: AsyncSession) -> None:
        """``hard_delete_org`` removes the org row entirely."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(
            OrgCreate(name="Hard Org", slug="hard-org")
        )

        assert await org_service.hard_delete_org(org.id) is True

        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == org.id)
        )
        assert raw.first() is None

    @pytest.mark.asyncio
    async def test_reregister_slug_after_soft_delete(
        self, async_db_session: AsyncSession
    ) -> None:
        """Same slug can be reused after the original org is soft-deleted.

        Exercises the partial unique index ``ix_organization_slug``.
        """
        org_service = OrgService(async_db_session)
        first = await org_service.create_org(
            OrgCreate(name="Acme", slug="acme")
        )
        await org_service.delete_org(first.id)

        second = await org_service.create_org(
            OrgCreate(name="Acme Returns", slug="acme")
        )
        assert second.id != first.id

        live = await org_service.get_org_by_slug("acme")
        assert live is not None
        assert live.id == second.id

    @pytest.mark.asyncio
    async def test_restore_org(self, async_db_session: AsyncSession) -> None:
        """``restore_org`` clears ``deleted_at`` on a soft-deleted org."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(
            OrgCreate(name="Restoreable", slug="restoreable")
        )
        await org_service.delete_org(org.id)
        assert await org_service.get_org_by_id(org.id) is None

        restored = await org_service.restore_org(org.id)
        assert restored is not None
        assert restored.id == org.id
        assert restored.deleted_at is None
        assert await org_service.get_org_by_id(org.id) is not None

    @pytest.mark.asyncio
    async def test_restore_org_noop_on_live(
        self, async_db_session: AsyncSession
    ) -> None:
        """``restore_org`` on a non-deleted org returns ``None``."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(
            OrgCreate(name="Live Org", slug="live-org")
        )
        assert await org_service.restore_org(org.id) is None

    @pytest.mark.asyncio
    async def test_restore_org_conflict_when_slug_reused(
        self, async_db_session: AsyncSession
    ) -> None:
        """Restore must refuse if the slug was reclaimed by re-creation."""
        org_service = OrgService(async_db_session)

        original = await org_service.create_org(
            OrgCreate(name="Acme", slug="acme")
        )
        await org_service.delete_org(original.id)
        replacement = await org_service.create_org(
            OrgCreate(name="Acme Returns", slug="acme")
        )
        assert replacement.id != original.id

        with pytest.raises(RestoreConflict):
            await org_service.restore_org(original.id)

        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == original.id)
        )
        row = raw.first()
        assert row is not None
        assert row.deleted_at is not None

    @pytest.mark.asyncio
    async def test_hard_delete_org_after_soft_delete(
        self, async_db_session: AsyncSession
    ) -> None:
        """``hard_delete_org`` purges an already-soft-deleted org."""
        org_service = OrgService(async_db_session)
        org = await org_service.create_org(
            OrgCreate(name="Soft Then Hard", slug="soft-then-hard")
        )
        await org_service.delete_org(org.id)
        assert await org_service.hard_delete_org(org.id) is True

        raw = await async_db_session.exec(
            select(Organization).where(Organization.id == org.id)
        )
        assert raw.first() is None

    @pytest.mark.asyncio
    async def test_list_orgs(self, async_db_session: AsyncSession) -> None:
        """Test listing organizations."""
        org_service = OrgService(async_db_session)
        await org_service.create_org(OrgCreate(name="Org A", slug="org-a"))
        await org_service.create_org(OrgCreate(name="Org B", slug="org-b"))

        orgs = await org_service.list_orgs()
        assert len(orgs) >= 2
        slugs = {o.slug for o in orgs}
        assert "org-a" in slugs
        assert "org-b" in slugs


class TestMembershipServiceIntegration:
    """Test membership service operations."""

    async def _create_user(
        self, db: AsyncSession, email: str
    ) -> "User":
        """Helper to create a test user."""
        from app.models.user import User
        user_service = UserService(db)
        return await user_service.create_user(
            UserCreate(email=email, full_name="Test", password="password123")
        )

    async def _create_org(
        self, db: AsyncSession, slug: str
