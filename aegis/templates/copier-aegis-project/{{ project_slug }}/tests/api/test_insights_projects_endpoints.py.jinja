class TestListProjects:
    @pytest.mark.asyncio
    async def test_filters_by_owner(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, alice_org, alice_headers = await _seed_user_and_token(
            async_db_session, "alice@x.com"
        )
        _, bob_org, bob_headers = await _seed_user_and_token(
            async_db_session, "bob@x.com"
        )
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": alice_org, "slug": "alice-1", "name": "A1"},
            headers=alice_headers,
        )
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": bob_org, "slug": "bob-1", "name": "B1"},
            headers=bob_headers,
        )

        alice_list = async_client_with_db.get(
            "/api/v1/insights/projects", headers=alice_headers
        )

        slugs = {p["slug"] for p in alice_list.json()}
        assert slugs == {"alice-1"}


