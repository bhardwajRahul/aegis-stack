"""Tests for the project CRUD HTTP API.

The route surface is gated on ``insights_per_user``, so this file
only ships in stacks that have per-user insights enabled.

Auth uses bearer tokens directly (mint via ``create_access_token``)
to avoid the cookie-jar bleed-across-tests footgun and to skip the
rate limiter that protects ``/auth/token``.
"""

from fastapi import status
from fastapi.testclient import TestClient
import pytest
from sqlmodel.ext.asyncio.session import AsyncSession

from app.core.config import settings
from app.core.security import create_access_token
from app.models.user import UserCreate
from app.services.auth.user_service import UserService


@pytest.fixture(autouse=True)
def _enable_auth():
    """Force real auth on for this module."""
    prior = settings.AUTH_ENABLED
    settings.AUTH_ENABLED = True
    try:
        yield
    finally:
        settings.AUTH_ENABLED = prior


async def _seed_user_and_token(
    session: AsyncSession, email: str = "u@example.com"
) -> tuple[int, int, dict[str, str]]:
    """Create a user + org + owner membership, return (user_id, org_id, auth_headers).

    The org is required since ``Project.organization_id`` is NOT NULL
    (per_user variant). Returned as a tuple so tests can include the
    org id in their POST bodies — the API endpoint verifies the
    caller is a member of the org before creating the project.
    """
    from tests._test_org import ensure_org_for_user

    svc = UserService(session)
    user = await svc.create_user(
        UserCreate(email=email, full_name="T", password="p"*12)
    )
    org_id = await ensure_org_for_user(session, user)
    token = create_access_token(data={"sub": user.email})
    return user.id, org_id, {"Authorization": f"Bearer {token}"}


# ---------------------------------------------------------------------------
# POST /projects
# ---------------------------------------------------------------------------


class TestCreateProject:
    @pytest.mark.asyncio
    async def test_returns_201_with_response_body(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, org_id, headers = await _seed_user_and_token(async_db_session)

        response = async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, "slug": "my-project", "name": "My Project"},
            headers=headers,
        )

        assert response.status_code == status.HTTP_201_CREATED
        body = response.json()
        assert body["slug"] == "my-project"
        assert body["name"] == "My Project"
        assert body["id"]

    @pytest.mark.asyncio
    async def test_owner_is_current_user_not_request_body(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        """Client cannot impersonate by sending owner_user_id."""
        user_id, org_id, headers = await _seed_user_and_token(async_db_session)

        response = async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, 
                "slug": "proj",
                "name": "P",
                "owner_user_id": 99999,  # ignored by ProjectCreate schema
            },
            headers=headers,
        )

        assert response.status_code == status.HTTP_201_CREATED
        assert response.json()["owner_user_id"] == user_id

    @pytest.mark.asyncio
    async def test_credentials_are_masked_in_response(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, org_id, headers = await _seed_user_and_token(async_db_session)

        response = async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, 
                "slug": "proj",
                "name": "P",
                "github_token": "ghp_abcdef123456",
                "plausible_api_key": "pk_abcdefghij",
            },
            headers=headers,
        )

        assert response.status_code == status.HTTP_201_CREATED
        body = response.json()
        assert body["github_token_masked"] == "***3456"
        assert body["plausible_api_key_masked"] == "***ghij"
        # And the raw fields are not in the response.
        assert "github_token" not in body
        assert "plausible_api_key" not in body

    @pytest.mark.asyncio
    async def test_returns_409_on_duplicate_slug(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, org_id, headers = await _seed_user_and_token(async_db_session)

        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, "slug": "proj", "name": "P"},
            headers=headers,
        )
        response = async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, "slug": "proj", "name": "Different Name"},
            headers=headers,
        )

        assert response.status_code == status.HTTP_409_CONFLICT

    @pytest.mark.asyncio
    async def test_returns_422_on_invalid_slug(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        """Slug must be lowercase + digits + hyphens, 3–64 chars."""
        _, org_id, headers = await _seed_user_and_token(async_db_session)

        for bad_slug in ["UPPER", "with spaces", "ab", "-leading", "trailing-"]:
            response = async_client_with_db.post(
                "/api/v1/insights/projects",
                json={"organization_id": org_id, "slug": bad_slug, "name": "P"},
                headers=headers,
            )
            assert response.status_code == status.HTTP_422_UNPROCESSABLE_ENTITY, (
                f"slug={bad_slug!r} should be rejected"
            )

    @pytest.mark.asyncio
    async def test_returns_401_without_auth(
        self,
        async_client_with_db: TestClient,
    ) -> None:
        # 401 short-circuits before schema validation, so ``organization_id=1``
        # is just a placeholder — it doesn't need to point at a real org.
        response = async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": 1, "slug": "proj", "name": "P"},
        )
        assert response.status_code == status.HTTP_401_UNAUTHORIZED


