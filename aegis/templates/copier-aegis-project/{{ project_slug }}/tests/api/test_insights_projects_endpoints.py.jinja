class TestUpdateProject:
    @pytest.mark.asyncio
    async def test_changes_only_provided_fields(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, org_id, headers = await _seed_user_and_token(async_db_session)
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, 
                "slug": "proj",
                "name": "Original",
                "github_owner": "lbedner",
                "github_repo": "aegis-stack",
            },
            headers=headers,
        )

        response = async_client_with_db.patch(
            "/api/v1/insights/projects/proj",
            json={"name": "Renamed"},
            headers=headers,
        )

        assert response.status_code == status.HTTP_200_OK
        body = response.json()
        assert body["name"] == "Renamed"
        # Untouched fields preserved.
        assert body["github_owner"] == "lbedner"
        assert body["github_repo"] == "aegis-stack"

    @pytest.mark.asyncio
    async def test_returns_404_for_non_owner(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, alice_org, alice_headers = await _seed_user_and_token(
            async_db_session, "alice@x.com"
        )
        _, bob_org, bob_headers = await _seed_user_and_token(
            async_db_session, "bob@x.com"
        )
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": alice_org, "slug": "alice-only", "name": "A"},
            headers=alice_headers,
        )

        response = async_client_with_db.patch(
            "/api/v1/insights/projects/alice-only",
            json={"name": "hacked"},
            headers=bob_headers,
        )

        assert response.status_code == status.HTTP_404_NOT_FOUND


