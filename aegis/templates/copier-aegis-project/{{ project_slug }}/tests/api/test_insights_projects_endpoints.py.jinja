class TestGetProjectInsights:
    @pytest.mark.asyncio
    async def test_returns_200_for_owner(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, org_id, headers = await _seed_user_and_token(async_db_session)
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, "slug": "proj", "name": "P"},
            headers=headers,
        )

        response = async_client_with_db.get(
            "/api/v1/insights/projects/proj/all", headers=headers
        )

        assert response.status_code == status.HTTP_200_OK
        # Response shape matches BulkInsightsResponse (empty for a fresh project).
        body = response.json()
        assert "daily" in body
        assert "events" in body
        assert "insight_events" in body
        assert "sources" in body

