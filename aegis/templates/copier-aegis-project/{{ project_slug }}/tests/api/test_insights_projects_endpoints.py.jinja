class TestDeleteProject:
    @pytest.mark.asyncio
    async def test_returns_204_and_removes_project(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, org_id, headers = await _seed_user_and_token(async_db_session)
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": org_id, "slug": "proj", "name": "P"},
            headers=headers,
        )

        delete_response = async_client_with_db.delete(
            "/api/v1/insights/projects/proj", headers=headers
        )
        get_response = async_client_with_db.get(
            "/api/v1/insights/projects/proj", headers=headers
        )

        assert delete_response.status_code == status.HTTP_204_NO_CONTENT
        assert get_response.status_code == status.HTTP_404_NOT_FOUND

    @pytest.mark.asyncio
    async def test_returns_404_for_non_owner(
        self,
        async_client_with_db: TestClient,
        async_db_session: AsyncSession,
    ) -> None:
        _, alice_org, alice_headers = await _seed_user_and_token(
            async_db_session, "alice@x.com"
        )
        _, bob_org, bob_headers = await _seed_user_and_token(
            async_db_session, "bob@x.com"
        )
        async_client_with_db.post(
            "/api/v1/insights/projects",
            json={"organization_id": alice_org, "slug": "alice-only", "name": "A"},
            headers=alice_headers,
        )

        response = async_client_with_db.delete(
            "/api/v1/insights/projects/alice-only", headers=bob_headers
        )

        assert response.status_code == status.HTTP_404_NOT_FOUND
        # And it's still there for alice.
        check = async_client_with_db.get(
            "/api/v1/insights/projects/alice-only", headers=alice_headers
        )
        assert check.status_code == status.HTTP_200_OK
