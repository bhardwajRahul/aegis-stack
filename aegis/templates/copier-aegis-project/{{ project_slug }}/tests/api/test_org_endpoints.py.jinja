        membership_service = MembershipService(db)
        await membership_service.add_member(org.id, user.id, role=ORG_ROLE_OWNER)
        token = create_access_token(data={"sub": user.email})
        return user, org, token

    @pytest.mark.asyncio
    async def test_create_invite(
        self, async_client_with_db: TestClient, async_db_session: AsyncSession
    ) -> None:
        """Create an invite for a new email."""
        _, org, token = await self._setup_org_with_owner(async_db_session)

        response = async_client_with_db.post(
            f"/api/v1/orgs/{org.id}/invites",
            json={"email": "newinvitee@test.com", "role": "member"},
            headers={"Authorization": f"Bearer {token}"},
        )

        assert response.status_code == status.HTTP_201_CREATED
        data = response.json()
        assert data["email"] == "newinvitee@test.com"
        assert data["status"] == "pending"

    @pytest.mark.asyncio
    async def test_invite_existing_user_auto_accepts(
        self, async_client_with_db: TestClient, async_db_session: AsyncSession
    ) -> None:
        """Inviting an existing user immediately adds them."""
        _, org, token = await self._setup_org_with_owner(async_db_session)

        user_service = UserService(async_db_session)
        await user_service.create_user(
            UserCreate(email="existinginv@test.com", full_name="Existing", password="password123")
        )

        response = async_client_with_db.post(
            f"/api/v1/orgs/{org.id}/invites",
            json={"email": "existinginv@test.com", "role": "admin"},
            headers={"Authorization": f"Bearer {token}"},
        )

        assert response.status_code == status.HTTP_201_CREATED
        assert response.json()["status"] == "accepted"

    @pytest.mark.skip(
        reason=(
            "Flaky: same DB-session isolation issue as "
            "``test_user_persistence_across_requests`` in test_auth_endpoints. "
            "Passes alone, 401s on the register-then-login handshake when "
            "run with siblings. Audit pending."
        )
    )
    @pytest.mark.asyncio
    async def test_register_accepts_pending_invite(
        self, async_client_with_db: TestClient, async_db_session: AsyncSession
    ) -> None:
        """Registering with a pending invite auto-adds to org."""
        _, org, token = await self._setup_org_with_owner(async_db_session)

        async_client_with_db.post(
            f"/api/v1/orgs/{org.id}/invites",
            json={"email": "willregister@test.com"},
            headers={"Authorization": f"Bearer {token}"},
        )

        response = async_client_with_db.post(
            "/api/v1/auth/register",
            json={
                "email": "willregister@test.com",
                "full_name": "New User",
                "password": "password123",
            },
        )

        assert response.status_code == status.HTTP_200_OK
        new_user_id = response.json()["id"]

        membership_service = MembershipService(async_db_session)
        member = await membership_service.get_member(org.id, new_user_id)
        assert member is not None
        assert member.role == "member"

    @pytest.mark.asyncio
    async def test_list_pending_invites(
        self, async_client_with_db: TestClient, async_db_session: AsyncSession
    ) -> None:
        """List pending invites for an org."""
        _, org, token = await self._setup_org_with_owner(async_db_session)

        for email in ["list1@test.com", "list2@test.com"]:
            async_client_with_db.post(
                f"/api/v1/orgs/{org.id}/invites",
                json={"email": email},
                headers={"Authorization": f"Bearer {token}"},
            )

        response = async_client_with_db.get(
            f"/api/v1/orgs/{org.id}/invites",
            headers={"Authorization": f"Bearer {token}"},
        )

        assert response.status_code == status.HTTP_200_OK
        assert len(response.json()) == 2

