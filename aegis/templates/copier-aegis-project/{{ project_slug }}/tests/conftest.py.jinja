    from app.models.org import ORG_ROLE_OWNER
    from app.services.auth.membership_service import MembershipService

    user = await user_factory()
    org = await org_factory()
    membership = MembershipService(async_db_session)
    await membership.add_member(org.id, user.id, role=ORG_ROLE_OWNER)
    return user, org
