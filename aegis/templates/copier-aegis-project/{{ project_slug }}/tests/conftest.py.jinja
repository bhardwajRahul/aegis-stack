@pytest.fixture
async def owner_with_org(async_db_session: AsyncSession, user_factory, org_factory):
    """Compose ``user_factory`` + ``org_factory`` + owner membership.

    Returns ``(user, org)``. Use when a test needs a user-who-owns-an-org
    as setup but doesn't care about the specific details.
