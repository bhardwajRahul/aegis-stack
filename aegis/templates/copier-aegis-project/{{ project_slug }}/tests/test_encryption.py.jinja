"""
Tests for the symmetric encryption helper used to protect sensitive
column values (e.g., per-project GitHub PATs and Plausible API keys).

The helper derives a Fernet key deterministically from
``settings.SECRET_KEY`` so encrypted-at-rest data round-trips across
process restarts as long as the secret is stable. Rotating
``SECRET_KEY`` invalidates every previously-encrypted value — the same
contract Flet's ``flet.security.encrypt`` provides on the frontend.
"""

from __future__ import annotations

import pytest
from app.core.encryption import (
    decrypt_secret,
    encrypt_secret,
)
from cryptography.fernet import InvalidToken


class TestEncryption:
    def test_round_trip_returns_original_plaintext(self) -> None:
        plaintext = "ghp_abc123_a_real_looking_token"

        ciphertext = encrypt_secret(plaintext)
        recovered = decrypt_secret(ciphertext)

        assert recovered == plaintext

    def test_ciphertext_differs_from_plaintext(self) -> None:
        plaintext = "ghp_abc123"

        ciphertext = encrypt_secret(plaintext)

        assert ciphertext != plaintext
        assert plaintext not in ciphertext

    def test_two_encryptions_of_same_value_differ(self) -> None:
        """Fernet uses a fresh random IV per call, so ciphertexts must differ."""
        plaintext = "ghp_abc123"

        a = encrypt_secret(plaintext)
        b = encrypt_secret(plaintext)

        assert a != b
        assert decrypt_secret(a) == plaintext
        assert decrypt_secret(b) == plaintext

    def test_decrypt_with_wrong_key_raises(self, monkeypatch: pytest.MonkeyPatch) -> None:
        """Rotating SECRET_KEY invalidates existing ciphertexts."""
        from app.core.encryption import _reset_cache

        ciphertext = encrypt_secret("ghp_abc123")

        # Swap the secret and clear the cached Fernet so the next call
        # rebuilds with the new key.
        from app.core.config import settings

        monkeypatch.setattr(settings, "SECRET_KEY", "totally-different-secret")
        _reset_cache()

        # Fernet raises InvalidToken specifically on a key mismatch;
        # asserting the precise type keeps unrelated failures (e.g. the
        # cache mechanism throwing a TypeError) from masquerading as a
        # successful test.
        with pytest.raises(InvalidToken):
            decrypt_secret(ciphertext)

        # Restore for the rest of the test session.
        _reset_cache()

    def test_encrypt_handles_empty_string(self) -> None:
        ciphertext = encrypt_secret("")
        assert decrypt_secret(ciphertext) == ""

    def test_encrypt_handles_unicode(self) -> None:
        plaintext = "tøken-with-üñïcödé-✨"
        ciphertext = encrypt_secret(plaintext)
        assert decrypt_secret(ciphertext) == plaintext
